#!/usr/bin/env python3

import argparse
import json
import os
import sys
from dataclasses import dataclass, field
from pathlib import Path
from typing import Dict, Iterable, List, Sequence, Tuple


IMPLEMENTATION_EXTENSIONS = {
    ".c",
    ".cc",
    ".cpp",
    ".cxx",
    ".c++",
    ".cp",
    ".m",
    ".mm",
    ".ixx",
    ".cppm",
    ".omegasl"
}

HEADER_EXTENSIONS = {
    ".h",
    ".hh",
    ".hpp",
    ".hxx",
    ".h++",
    ".inl",
    ".inc",
    ".ipp",
    ".tpp",
}


@dataclass(frozen=True)
class ModuleConfig:
    name: str
    root_dir: str
    src_dir: str = "src"
    include_dir: str = "include"
    dependency_dirs: Sequence[str] = ()


@dataclass
class BucketStats:
    files: int = 0
    lines: int = 0
    nonblank_lines: int = 0

    def add_file(self, lines: int, nonblank_lines: int) -> None:
        self.files += 1
        self.lines += lines
        self.nonblank_lines += nonblank_lines

    def add_bucket(self, other: "BucketStats") -> None:
        self.files += other.files
        self.lines += other.lines
        self.nonblank_lines += other.nonblank_lines

    def to_dict(self) -> Dict[str, int]:
        return {
            "files": self.files,
            "lines": self.lines,
            "nonblank_lines": self.nonblank_lines,
        }


@dataclass
class ModuleStats:
    name: str
    module_path: str
    src_path: str
    include_path: str
    dependency_paths: List[str] = field(default_factory=list)
    implementation: BucketStats = field(default_factory=BucketStats)
    private_headers: BucketStats = field(default_factory=BucketStats)
    public_headers: BucketStats = field(default_factory=BucketStats)
    other: BucketStats = field(default_factory=BucketStats)
    source_code_bytes: int = 0
    deps_bytes: int = 0
    total_bytes: int = 0

    def total_files(self) -> int:
        return (
            self.implementation.files
            + self.private_headers.files
            + self.public_headers.files
            + self.other.files
        )

    def total_lines(self) -> int:
        return (
            self.implementation.lines
            + self.private_headers.lines
            + self.public_headers.lines
            + self.other.lines
        )

    def total_nonblank_lines(self) -> int:
        return (
            self.implementation.nonblank_lines
            + self.private_headers.nonblank_lines
            + self.public_headers.nonblank_lines
            + self.other.nonblank_lines
        )

    def add_module(self, other: "ModuleStats") -> None:
        self.implementation.add_bucket(other.implementation)
        self.private_headers.add_bucket(other.private_headers)
        self.public_headers.add_bucket(other.public_headers)
        self.other.add_bucket(other.other)
        self.source_code_bytes += other.source_code_bytes
        self.deps_bytes += other.deps_bytes
        self.total_bytes += other.total_bytes

    def to_dict(self) -> Dict[str, object]:
        return {
            "name": self.name,
            "paths": {
                "module": self.module_path,
                "src": self.src_path,
                "include": self.include_path,
                "dependencies": self.dependency_paths,
            },
            "implementation": self.implementation.to_dict(),
            "private_headers": self.private_headers.to_dict(),
            "public_headers": self.public_headers.to_dict(),
            "other": self.other.to_dict(),
            "sizes": {
                "source_code_bytes": self.source_code_bytes,
                "deps_bytes": self.deps_bytes,
                "total_bytes": self.total_bytes,
            },
            "totals": {
                "files": self.total_files(),
                "lines": self.total_lines(),
                "nonblank_lines": self.total_nonblank_lines(),
            },
        }


MODULES: Sequence[ModuleConfig] = (
    ModuleConfig(name="OmegaCommon", root_dir="common", dependency_dirs=("deps",)),
    ModuleConfig(name="OmegaGTE", root_dir="gte", dependency_dirs=("deps",)),
    ModuleConfig(name="OmegaWTK", root_dir="wtk", dependency_dirs=("deps",)),
    ModuleConfig(name="AUTOM", root_dir="autom", dependency_dirs=("deps",)),
    ModuleConfig(name="AQUA", root_dir="aqua", src_dir="src", include_dir="include", dependency_dirs=("deps",)),
)


def detect_repo_root(script_path: Path) -> Path:
    repo_root = script_path.resolve().parent.parent
    return validate_repo_root(
        repo_root,
        "Could not locate repository root from script location. "
        "Expected a CMakeLists.txt alongside the module directories.",
    )


def validate_repo_root(repo_root: Path, error_message: str) -> Path:
    if not (repo_root / "CMakeLists.txt").is_file():
        raise RuntimeError(error_message)
    return repo_root


def iter_files(directory: Path) -> Iterable[Path]:
    if not directory.is_dir():
        return ()
    return sorted(path for path in directory.rglob("*") if path.is_file())


def resolve_module_paths(repo_root: Path, config: ModuleConfig) -> Tuple[Path, Path]:
    module_root = repo_root / config.root_dir
    src_path = module_root / config.src_dir
    include_path = module_root / config.include_dir
    if src_path.is_dir() or include_path.is_dir():
        return src_path, include_path

    expected_paths = ", ".join(
        str((Path(config.root_dir) / scan_dir).as_posix())
        for scan_dir in (config.src_dir, config.include_dir)
    )
    raise RuntimeError(
        f"{config.name} stats scan directories were not found. "
        f"Expected at least one of: {expected_paths}. "
        "Update utils/repo-stats to match the module source tree before collecting stats."
    )


def count_lines(path: Path) -> Tuple[int, int]:
    total_lines = 0
    nonblank_lines = 0

    with path.open("r", encoding="utf-8", errors="replace") as stream:
        for line in stream:
            total_lines += 1
            if line.strip():
                nonblank_lines += 1

    return total_lines, nonblank_lines


def is_relative_to(path: Path, other: Path) -> bool:
    try:
        path.relative_to(other)
        return True
    except ValueError:
        return False


def normalize_directories(paths: Iterable[Path]) -> List[Path]:
    unique_paths: List[Path] = []
    for path in sorted((path for path in paths if path.is_dir()), key=lambda item: len(item.parts)):
        if any(is_relative_to(path, existing_path) for existing_path in unique_paths):
            continue
        unique_paths.append(path)
    return unique_paths


def count_bytes(directory: Path) -> int:
    if not directory.is_dir():
        return 0

    total_bytes = 0
    for root, _, filenames in os.walk(directory, followlinks=False):
        root_path = Path(root)
        for filename in filenames:
            total_bytes += (root_path / filename).stat(follow_symlinks=False).st_size

    return total_bytes


def classify_file(path: Path, public_header_tree: bool) -> str:
    extension = path.suffix.lower()

    if extension in HEADER_EXTENSIONS:
        return "public_headers" if public_header_tree else "private_headers"
    if extension in IMPLEMENTATION_EXTENSIONS:
        return "implementation"
    return "other"


def scan_tree(directory: Path, stats: ModuleStats, public_header_tree: bool) -> None:
    for path in iter_files(directory):
        lines, nonblank_lines = count_lines(path)
        bucket_name = classify_file(path, public_header_tree)
        getattr(stats, bucket_name).add_file(lines, nonblank_lines)


def scan_module(repo_root: Path, config: ModuleConfig) -> ModuleStats:
    module_root = repo_root / config.root_dir
    src_path, include_path = resolve_module_paths(repo_root, config)
    dependency_paths = [module_root / dependency_dir for dependency_dir in config.dependency_dirs]
    normalized_dependency_paths = normalize_directories(dependency_paths)
    stats = ModuleStats(
        name=config.name,
        module_path=str(module_root.relative_to(repo_root)),
        src_path=str(src_path.relative_to(repo_root)),
        include_path=str(include_path.relative_to(repo_root)),
        dependency_paths=[
            str(path.relative_to(repo_root)) for path in normalized_dependency_paths
        ],
        deps_bytes=sum(count_bytes(path) for path in normalized_dependency_paths),
        total_bytes=count_bytes(module_root),
    )
    stats.source_code_bytes = stats.total_bytes - stats.deps_bytes

    scan_tree(src_path, stats, public_header_tree=False)
    scan_tree(include_path, stats, public_header_tree=True)
    return stats


def build_total_stats(module_stats: Sequence[ModuleStats]) -> ModuleStats:
    total = ModuleStats(name="TOTAL", module_path="-", src_path="-", include_path="-")
    for stats in module_stats:
        total.add_module(stats)
    total.source_code_bytes = total.total_bytes - total.deps_bytes
    return total


def format_number(value: int) -> str:
    return f"{value:,}"


def format_bytes(value: int) -> str:
    units = ("B", "KiB", "MiB", "GiB", "TiB")
    size = float(value)
    unit_index = 0
    while size >= 1024.0 and unit_index < len(units) - 1:
        size /= 1024.0
        unit_index += 1

    if unit_index == 0:
        return f"{value} {units[unit_index]}"
    return f"{size:.1f} {units[unit_index]}"


def render_table(headers: Sequence[str], rows: Sequence[Sequence[str]]) -> str:
    widths = [len(header) for header in headers]
    for row in rows:
        for index, cell in enumerate(row):
            widths[index] = max(widths[index], len(cell))

    rendered_rows = []
    rendered_rows.append("  ".join(cell.ljust(widths[index]) for index, cell in enumerate(headers)))
    rendered_rows.append("  ".join("-" * width for width in widths))

    for row in rows:
        rendered_rows.append("  ".join(cell.rjust(widths[index]) if index else cell.ljust(widths[index]) for index, cell in enumerate(row)))

    return "\n".join(rendered_rows)


def build_count_rows(module_stats: Sequence[ModuleStats]) -> List[List[str]]:
    rows: List[List[str]] = []
    for stats in module_stats:
        rows.append(
            [
                stats.name,
                format_number(stats.total_files()),
                format_number(stats.implementation.files),
                format_number(stats.private_headers.files),
                format_number(stats.public_headers.files),
                format_number(stats.other.files),
            ]
        )
    return rows


def build_line_rows(module_stats: Sequence[ModuleStats]) -> List[List[str]]:
    rows: List[List[str]] = []
    for stats in module_stats:
        rows.append(
            [
                stats.name,
                format_number(stats.implementation.lines),
                format_number(stats.private_headers.lines),
                format_number(stats.public_headers.lines),
                format_number(stats.other.lines),
                format_number(stats.total_lines()),
                format_number(stats.total_nonblank_lines()),
            ]
        )
    return rows


def build_size_rows(module_stats: Sequence[ModuleStats]) -> List[List[str]]:
    rows: List[List[str]] = []
    for stats in module_stats:
        rows.append(
            [
                stats.name,
                format_bytes(stats.source_code_bytes),
                format_bytes(stats.deps_bytes),
                format_bytes(stats.total_bytes),
            ]
        )
    return rows


def emit_text_report(repo_root: Path, module_stats: Sequence[ModuleStats], repo_root_total_bytes: int) -> None:
    total_stats = build_total_stats(module_stats)
    summary_rows = build_count_rows([*module_stats, total_stats])
    line_rows = build_line_rows([*module_stats, total_stats])
    size_rows = build_size_rows([*module_stats, total_stats])

    print("Omega Graphics Project repository stats")
    print("Repository root:", repo_root)
    print()
    print("File counts")
    print(
        render_table(
            ["Module", "Files", "Impl", "PrivHdr", "PubHdr", "Other"],
            summary_rows,
        )
    )
    print()
    print("Line counts")
    print(
        render_table(
            ["Module", "ImplLines", "PrivHdrLines", "PubHdrLines", "OtherLines", "TotalLines", "Nonblank"],
            line_rows,
        )
    )
    print()
    print("Disk usage")
    print(
        render_table(
            ["Module", "SourceCode", "Deps", "Total"],
            size_rows,
        )
    )
    print()
    print("Repository root total:", format_bytes(repo_root_total_bytes))
    print()
    print("Scan roots")
    for stats in module_stats:
        dependency_paths = ", ".join(stats.dependency_paths) if stats.dependency_paths else "-"
        print(
            f"{stats.name}: module={stats.module_path} src={stats.src_path} "
            f"include={stats.include_path} deps={dependency_paths}"
        )


def emit_json_report(repo_root: Path, module_stats: Sequence[ModuleStats], repo_root_total_bytes: int) -> None:
    total_stats = build_total_stats(module_stats)
    payload = {
        "repository_root": str(repo_root),
        "repository_root_total_bytes": repo_root_total_bytes,
        "modules": [stats.to_dict() for stats in module_stats],
        "aggregate": total_stats.to_dict(),
    }
    json.dump(payload, sys.stdout, indent=2)
    sys.stdout.write("\n")


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description=(
            "Report source/header file counts, line counts, and disk usage for the Omega Graphics Project modules."
        )
    )
    parser.add_argument(
        "--root",
        type=Path,
        default=None,
        help="Repository root to scan. Defaults to the root detected from the script location.",
    )
    parser.add_argument(
        "--json",
        action="store_true",
        help="Emit the report as JSON instead of a text table.",
    )
    return parser.parse_args()


def main() -> int:
    args = parse_args()

    try:
        if args.root is not None:
            repo_root = validate_repo_root(
                args.root.resolve(),
                "The supplied --root path does not look like the repository root.",
            )
        else:
            repo_root = detect_repo_root(Path(__file__))
        module_stats = [scan_module(repo_root, config) for config in MODULES]
        repo_root_total_bytes = count_bytes(repo_root)
    except RuntimeError as exc:
        print(f"error: {exc}", file=sys.stderr)
        return 1

    if args.json:
        emit_json_report(repo_root, module_stats, repo_root_total_bytes)
    else:
        emit_text_report(repo_root, module_stats, repo_root_total_bytes)

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
