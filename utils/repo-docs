#!/usr/bin/env python3

import argparse
import html
import json
import os
import shutil
import subprocess
import sys
import tempfile
from dataclasses import dataclass
from pathlib import Path
from typing import Dict, List, Optional, Sequence, Tuple


MODULE_ORDER: Tuple[str, ...] = (
    "OmegaCommon",
    "OmegaGTE",
    "OmegaWTK",
    "AUTOM",
    "AQUA",
)

REPO_SPHINX_SITE_KEY = "OmegaGraphicsProject"
REPO_SPHINX_SITE_TITLE = "Omega Graphics Project"


@dataclass(frozen=True)
class ModuleConfig:
    name: str
    root_dir: str
    input_dirs: Tuple[str, ...]
    dependencies: Tuple[str, ...] = ()
    base_doxyfile: Optional[str] = "Doxyfile"
    project_brief: str = ""


@dataclass(frozen=True)
class SphinxSite:
    key: str
    title: str
    source_dir: Path
    output_dir: Path


MODULES: Sequence[ModuleConfig] = (
    ModuleConfig(
        name="OmegaCommon",
        root_dir="common",
        input_dirs=("src", "include"),
        project_brief="Common utilities and shared platform support for the Omega Graphics Project.",
    ),
    ModuleConfig(
        name="OmegaGTE",
        root_dir="gte",
        input_dirs=("src", "include"),
        dependencies=("OmegaCommon",),
        project_brief="Rendering and graphics technology layer for the Omega Graphics Project.",
    ),
    ModuleConfig(
        name="OmegaWTK",
        root_dir="wtk",
        input_dirs=("src", "include"),
        dependencies=("OmegaCommon", "OmegaGTE"),
        project_brief="Widget toolkit built on top of the Omega graphics stack.",
    ),
    ModuleConfig(
        name="AUTOM",
        root_dir="autom",
        input_dirs=("src", "modules"),
        base_doxyfile=None,
        project_brief="AUTOM build tooling and execution engine.",
    ),
    ModuleConfig(
        name="AQUA",
        root_dir="aqua",
        input_dirs=("src", "include"),
        dependencies=("OmegaGTE",),
        project_brief="AQUA engine module built on top of OmegaGTE.",
    ),
)


SUPPRESSED_OUTPUT_TAGS: Tuple[str, ...] = (
    "GENERATE_LATEX",
    "GENERATE_MAN",
    "GENERATE_RTF",
    "GENERATE_XML",
    "GENERATE_DOCBOOK",
    "GENERATE_QHP",
    "GENERATE_ECLIPSEHELP",
    "GENERATE_DOCSET",
    "GENERATE_SQLITE3",
)


def detect_repo_root(script_path: Path) -> Path:
    repo_root = script_path.resolve().parent.parent
    return validate_repo_root(
        repo_root,
        "Could not locate repository root from script location. "
        "Expected the repository CMakeLists.txt at the root.",
    )


def validate_repo_root(repo_root: Path, error_message: str) -> Path:
    if not (repo_root / "CMakeLists.txt").is_file():
        raise RuntimeError(error_message)
    return repo_root


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description=(
            "Generate Doxygen and Sphinx HTML documentation for the Omega Graphics Project "
            "modules, including cross-module Doxygen tagfile links."
        )
    )
    parser.add_argument(
        "--root",
        type=Path,
        default=None,
        help="Repository root to scan. Defaults to the root detected from the script location.",
    )
    parser.add_argument(
        "--output",
        type=Path,
        default=Path("build/doxygen"),
        help="Output directory relative to the repository root by default.",
    )
    parser.add_argument(
        "--module",
        dest="modules",
        action="append",
        choices=MODULE_ORDER,
        help="Generate docs for only the named module. May be passed more than once.",
    )
    parser.add_argument(
        "--doxygen",
        default="doxygen",
        help="Doxygen executable to invoke. Defaults to `doxygen` from PATH.",
    )
    parser.add_argument(
        "--sphinx",
        default="sphinx-build",
        help="sphinx-build executable to invoke. Defaults to `sphinx-build` from PATH.",
    )
    parser.add_argument(
        "--no-sphinx",
        action="store_true",
        help="Skip Sphinx documentation generation.",
    )
    parser.add_argument(
        "--clean",
        action="store_true",
        help="Delete the output directory before generating documentation.",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Print the work plan without invoking doxygen or sphinx-build.",
    )
    parser.add_argument(
        "--verbose",
        action="store_true",
        help="Print the generated config paths and commands as they are used.",
    )
    return parser.parse_args()


def resolve_output_directory(repo_root: Path, output_arg: Path) -> Path:
    if output_arg.is_absolute():
        return output_arg
    return repo_root / output_arg


def select_modules(selected_names: Optional[Sequence[str]]) -> List[ModuleConfig]:
    module_map = {module.name: module for module in MODULES}
    if not selected_names:
        return list(MODULES)
    return [module_map[name] for name in MODULE_ORDER if name in selected_names]


def ensure_doxygen_available(executable: str) -> None:
    if shutil.which(executable) is None:
        raise RuntimeError(
            f"Could not find `{executable}` in PATH. Install Doxygen or pass --doxygen with an explicit path."
        )


def quote_value(value: str) -> str:
    escaped = value.replace("\\", "\\\\").replace('"', '\\"')
    return f"\"{escaped}\""


def relative_input_dirs(repo_root: Path, module: ModuleConfig) -> List[str]:
    module_root = repo_root / module.root_dir
    inputs = []
    for input_dir in module.input_dirs:
        candidate = module_root / input_dir
        if candidate.exists():
            inputs.append(str(candidate.relative_to(repo_root)))
    return inputs


def resolve_input_dirs(repo_root: Path, module: ModuleConfig) -> List[str]:
    input_dirs = relative_input_dirs(repo_root, module)
    if input_dirs:
        return input_dirs

    expected_paths = ", ".join(
        str((Path(module.root_dir) / input_dir).as_posix()) for input_dir in module.input_dirs
    )
    raise RuntimeError(
        f"{module.name} documentation input directories were not found. "
        f"Expected at least one of: {expected_paths}. "
        "Update utils/repo-docs to match the module source tree before generating docs."
    )


def module_output_dir(output_root: Path, module: ModuleConfig) -> Path:
    return output_root / module.name


def module_html_dir(output_root: Path, module: ModuleConfig) -> Path:
    return module_output_dir(output_root, module) / "html"


def module_tagfile(output_root: Path, module: ModuleConfig) -> Path:
    return module_output_dir(output_root, module) / f"{module.name}.tag"


def build_tagfiles_line(
    module: ModuleConfig,
    selected_modules: Sequence[ModuleConfig],
    output_root: Path,
) -> str:
    current_html_dir = module_html_dir(output_root, module)
    entries: List[str] = []

    for other in selected_modules:
        if other.name == module.name:
            continue
        tag_path = module_tagfile(output_root, other)
        html_path = module_html_dir(output_root, other)
        relative_html = os.path.relpath(html_path, start=current_html_dir)
        entries.append(quote_value(f"{tag_path}={relative_html}"))

    if not entries:
        return "TAGFILES               ="

    return "TAGFILES               = " + " ".join(entries)


def synthetic_autom_config(repo_root: Path, module: ModuleConfig) -> List[str]:
    inputs = resolve_input_dirs(repo_root, module)
    lines = [
        f"PROJECT_NAME           = {quote_value(module.name)}",
        f"PROJECT_BRIEF          = {quote_value(module.project_brief)}",
        "OPTIMIZE_OUTPUT_FOR_C  = NO",
        "EXTRACT_ALL            = YES",
        "EXTRACT_PRIVATE        = YES",
        "EXTRACT_STATIC         = YES",
        "RECURSIVE              = YES",
        "QUIET                  = YES",
        "WARN_IF_UNDOCUMENTED   = NO",
        "WARN_IF_DOC_ERROR      = YES",
        "JAVADOC_AUTOBRIEF      = YES",
        "MULTILINE_CPP_IS_BRIEF = YES",
    ]

    lines.append("INPUT                  = " + " ".join(quote_value(path) for path in inputs))

    lines.extend(
        [
            "FILE_PATTERNS          = *.c *.cc *.cxx *.cpp *.c++ *.h *.hh *.hxx *.hpp *.h++ *.inl *.ipp *.tpp *.py *.md *.dox *.def",
            "EXTENSION_MAPPING      = def=C++",
        ]
    )
    return lines


def build_override_lines(
    repo_root: Path,
    output_root: Path,
    module: ModuleConfig,
    selected_modules: Sequence[ModuleConfig],
    html_enabled: bool,
) -> List[str]:
    input_dirs = resolve_input_dirs(repo_root, module)
    module_dir = module_output_dir(output_root, module)
    tagfile = module_tagfile(output_root, module)
    strip_from_path = str(repo_root)

    lines = [
        f"OUTPUT_DIRECTORY       = {quote_value(str(module_dir))}",
        "HTML_OUTPUT            = html",
        f"GENERATE_TAGFILE       = {quote_value(str(tagfile))}",
        f"STRIP_FROM_PATH        = {quote_value(strip_from_path)}",
        "FULL_PATH_NAMES        = YES",
        "RECURSIVE              = YES",
        "EXTRACT_ALL            = YES",
        "WARN_IF_UNDOCUMENTED   = NO",
        "QUIET                  = YES",
        "WARN_IF_DOC_ERROR      = YES",
        f"PROJECT_BRIEF          = {quote_value(module.project_brief)}",
    ]

    lines.append("INPUT                  = " + " ".join(quote_value(path) for path in input_dirs))
    lines.append("INCLUDE_PATH           = " + " ".join(quote_value(path) for path in input_dirs))

    if html_enabled:
        lines.append("GENERATE_HTML          = YES")
        lines.append(build_tagfiles_line(module, selected_modules, output_root))
    else:
        lines.append("GENERATE_HTML          = NO")
        lines.append("TAGFILES               =")

    for tag_name in SUPPRESSED_OUTPUT_TAGS:
        lines.append(f"{tag_name:<23}= NO")

    return lines


def write_config_file(
    config_dir: Path,
    repo_root: Path,
    output_root: Path,
    module: ModuleConfig,
    selected_modules: Sequence[ModuleConfig],
    html_enabled: bool,
) -> Path:
    config_path = config_dir / f"{module.name}-{'html' if html_enabled else 'tags'}.doxyfile"
    lines: List[str] = []

    if module.base_doxyfile is not None:
        base_path = repo_root / module.root_dir / module.base_doxyfile
        lines.append(f"@INCLUDE               = {quote_value(str(base_path))}")
    else:
        lines.extend(synthetic_autom_config(repo_root, module))

    lines.append("")
    lines.extend(build_override_lines(repo_root, output_root, module, selected_modules, html_enabled))
    lines.append("")

    config_path.write_text("\n".join(lines), encoding="utf-8")
    return config_path


def run_doxygen(
    executable: str,
    config_path: Path,
    working_directory: Path,
    dry_run: bool,
    verbose: bool,
) -> None:
    command = [executable, str(config_path)]
    if dry_run or verbose:
        print(" ".join(command))
    if dry_run:
        return

    subprocess.run(command, cwd=working_directory, check=True)


def has_sphinx_docs(repo_root: Path, module: ModuleConfig) -> bool:
    return (repo_root / module.root_dir / "docs" / "conf.py").is_file()


def module_sphinx_dir(output_root: Path, module: ModuleConfig) -> Path:
    return module_output_dir(output_root, module) / "sphinx"


def has_repo_sphinx_docs(repo_root: Path) -> bool:
    return (repo_root / "docs" / "conf.py").is_file()


def repo_sphinx_dir(output_root: Path) -> Path:
    return output_root / "sphinx"


def collect_sphinx_sites(
    repo_root: Path,
    output_root: Path,
    selected_modules: Sequence[ModuleConfig],
) -> List[SphinxSite]:
    sites: List[SphinxSite] = []

    if has_repo_sphinx_docs(repo_root):
        sites.append(
            SphinxSite(
                key=REPO_SPHINX_SITE_KEY,
                title=REPO_SPHINX_SITE_TITLE,
                source_dir=repo_root / "docs",
                output_dir=repo_sphinx_dir(output_root),
            )
        )

    for module in selected_modules:
        if not has_sphinx_docs(repo_root, module):
            continue
        sites.append(
            SphinxSite(
                key=module.name,
                title=module.name,
                source_dir=repo_root / module.root_dir / "docs",
                output_dir=module_sphinx_dir(output_root, module),
            )
        )

    return sites


def build_sphinx_nav(current_site: SphinxSite, all_sites: Sequence[SphinxSite]) -> List[Dict[str, object]]:
    nav_items: List[Dict[str, object]] = []
    for site in all_sites:
        target_index = site.output_dir / "index.html"
        relative_target = os.path.relpath(target_index, start=current_site.output_dir)
        nav_items.append(
            {
                "title": site.title,
                "path": Path(relative_target).as_posix(),
                "current": site.key == current_site.key,
            }
        )
    return nav_items


def build_sphinx_environment(current_site: SphinxSite, all_sites: Sequence[SphinxSite]) -> Dict[str, str]:
    environment = os.environ.copy()
    environment["OMEGA_SPHINX_NAV_JSON"] = json.dumps(build_sphinx_nav(current_site, all_sites))
    return environment


def ensure_sphinx_available(executable: str) -> None:
    if shutil.which(executable) is None:
        raise RuntimeError(
            f"Could not find `{executable}` in PATH. Install Sphinx or pass --sphinx with an explicit path."
        )


def run_sphinx_build(
    executable: str,
    source_dir: Path,
    output_dir: Path,
    dry_run: bool,
    verbose: bool,
    environment: Optional[Dict[str, str]] = None,
) -> None:
    command = [executable, "-b", "html", str(source_dir), str(output_dir)]
    if dry_run or verbose:
        print(" ".join(command))
    if dry_run:
        return
    output_dir.mkdir(parents=True, exist_ok=True)
    subprocess.run(command, check=True, env=environment)


def landing_page_theme_href(output_root: Path, selected_modules: Sequence[ModuleConfig]) -> Optional[str]:
    candidates = [Path("sphinx") / "_static" / "theme.css"]
    candidates.extend(Path(module.name) / "sphinx" / "_static" / "theme.css" for module in selected_modules)

    for candidate in candidates:
        if (output_root / candidate).is_file():
            return candidate.as_posix()

    return None


def write_landing_page(
    output_root: Path,
    selected_modules: Sequence[ModuleConfig],
    sphinx_sites: Sequence[SphinxSite],
) -> None:
    theme_href = landing_page_theme_href(output_root, selected_modules)
    site_nav: List[Tuple[str, str, bool]] = [("Home", "https://omegagraphics.org", False)]

    for site in sphinx_sites:
        href = os.path.relpath(site.output_dir / "index.html", start=output_root)
        site_nav.append((site.title, Path(href).as_posix(), True))

    lines = [
        "<!doctype html>",
        "<html lang=\"en\">",
        "<head>",
        "  <meta charset=\"utf-8\">",
        "  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">",
        "  <title>Omega Graphics Project Documentation</title>",
        "  <meta name=\"theme-color\" content=\"#060812\">",
    ]

    if theme_href is not None:
        lines.append(f"  <link rel=\"stylesheet\" href=\"{theme_href}\">")

    lines.extend(
        [
            "  <style>",
            "    body.omegagraphics-docs { color-scheme: dark; }",
            "    .landing-main { padding: 36px 0 56px; }",
            "    .landing-main .section-heading h2 { max-width: 18ch; }",
            "    .landing-meta { margin-top: 16px; color: #d7e1ff; font-size: 0.94rem; font-weight: 600; }",
            "    .landing-main .docs-grid { grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); }",
            "    .landing-main .project-links { margin-top: 0; }",
            "    .landing-main .doc-card { min-height: 100%; }",
            "    @media (max-width: 720px) { .landing-main { padding-top: 24px; } }",
            "  </style>",
            "</head>",
            "<body class=\"omegagraphics-docs\">",
            "  <div class=\"site-shell\">",
            "    <header class=\"topbar\" role=\"banner\">",
            "      <a class=\"brand\" href=\"index.html\">",
            "        <span class=\"brand-mark\">OG</span>",
            "        <span class=\"brand-copy\">",
            "          <strong>Omega Graphics</strong>",
            "          <small>Documentation Hub</small>",
            "        </span>",
            "      </a>",
            "      <nav class=\"nav\" aria-label=\"Project\">",
        ]
    )

    for title, href, is_local in site_nav:
        escaped_title = html.escape(title)
        escaped_href = Path(href).as_posix() if is_local else href
        lines.append(f"        <a href=\"{escaped_href}\">{escaped_title}</a>")

    lines.extend(
        [
            "      </nav>",
            "    </header>",
            "    <main class=\"landing-main\">",
            "      <section class=\"module-summary\">",
            "        <div class=\"section-heading\">",
            "          <p class=\"eyebrow\">Docs Output</p>",
            "          <h2>Guides, build notes, and API references for the Omega Graphics Project.</h2>",
            "        </div>",
            "        <article class=\"module-summary-card\">",
            "          <p>This output tree combines the repo-level Sphinx docs, per-module Sphinx guides, and per-module Doxygen API references generated by <code>utils/repo-docs</code>.</p>",
            "        </article>",
            "      </section>",
            "      <section class=\"docs-section\">",
            "        <div class=\"section-heading\">",
            "          <p class=\"eyebrow\">Docs Sites</p>",
            "          <h2>Open the suite docs or jump straight into a module guide and API reference.</h2>",
            "        </div>",
            "        <div class=\"docs-grid\">",
        ]
    )

    repo_site = next((site for site in sphinx_sites if site.key == REPO_SPHINX_SITE_KEY), None)
    if repo_site is not None:
        repo_href = os.path.relpath(repo_site.output_dir / "index.html", start=output_root)
        lines.extend(
            [
                "          <article class=\"doc-card\">",
                "            <div>",
                f"              <strong>{html.escape(repo_site.title)}</strong>",
                "              <p>Suite-level documentation for the repository, including the build guide and shared project overview.</p>",
                "              <p class=\"landing-meta\">Shared entry point for the Omega Graphics docs suite.</p>",
                "            </div>",
                "            <div class=\"project-links\">",
                f"              <a class=\"text-link\" href=\"{Path(repo_href).as_posix()}\">Open Suite Docs</a>",
                "            </div>",
                "          </article>",
            ]
        )

    for module in selected_modules:
        deps = ", ".join(module.dependencies) if module.dependencies else "none"
        links: List[str] = []

        doxy_index = module_html_dir(output_root, module) / "index.html"
        if doxy_index.exists():
            href = doxy_index.relative_to(output_root).as_posix()
            links.append(f"              <a class=\"text-link\" href=\"{href}\">API (Doxygen)</a>")

        sphinx_index = module_sphinx_dir(output_root, module) / "index.html"
        if sphinx_index.exists():
            href = sphinx_index.relative_to(output_root).as_posix()
            links.append(f"              <a class=\"text-link\" href=\"{href}\">Guide (Sphinx)</a>")

        if not links:
            links.append("              <span class=\"landing-meta\">No docs were built for this module.</span>")

        lines.extend(
            [
                "          <article class=\"doc-card\">",
                "            <div>",
                f"              <strong>{html.escape(module.name)}</strong>",
                f"              <p>{html.escape(module.project_brief)}</p>",
                f"              <p class=\"landing-meta\">Dependencies: {html.escape(deps)}</p>",
                "            </div>",
                "            <div class=\"project-links\">",
                *links,
                "            </div>",
                "          </article>",
            ]
        )

    lines.extend(
        [
            "        </div>",
            "      </section>",
            "    </main>",
            "    <footer class=\"site-footer\" role=\"contentinfo\">",
            "      <p>Omega Graphics Project documentation</p>",
            "      <span>Doxygen output: <code>MODULE/html/</code> &nbsp; Sphinx output: <code>MODULE/sphinx/</code></span>",
            "    </footer>",
            "  </div>",
            "</body>",
            "</html>",
        ]
    )

    (output_root / "index.html").write_text("\n".join(lines), encoding="utf-8")


def validate_selected_modules(selected_modules: Sequence[ModuleConfig]) -> None:
    if not selected_modules:
        raise RuntimeError("No modules selected for documentation generation.")


def main() -> int:
    args = parse_args()

    try:
        if args.root is not None:
            repo_root = validate_repo_root(
                args.root.resolve(),
                "The supplied --root path does not look like the repository root.",
            )
        else:
            repo_root = detect_repo_root(Path(__file__))

        selected_modules = select_modules(args.modules)
        validate_selected_modules(selected_modules)
        output_root = resolve_output_directory(repo_root, args.output)

        run_sphinx = not args.no_sphinx
        sphinx_sites = collect_sphinx_sites(repo_root, output_root, selected_modules) if run_sphinx else []

        if not args.dry_run:
            ensure_doxygen_available(args.doxygen)
            if sphinx_sites:
                ensure_sphinx_available(args.sphinx)

        if args.clean and output_root.exists():
            shutil.rmtree(output_root)
        output_root.mkdir(parents=True, exist_ok=True)

        total_passes = 3 if sphinx_sites else 2

        with tempfile.TemporaryDirectory(prefix="repo-docs-") as temp_dir_name:
            config_dir = Path(temp_dir_name)

            print(f"Repository root: {repo_root}")
            print(f"Output root: {output_root}")
            print("Modules:", ", ".join(module.name for module in selected_modules))
            print(f"Pass 1/{total_passes}: generating tagfiles")

            for module in selected_modules:
                config_path = write_config_file(
                    config_dir,
                    repo_root,
                    output_root,
                    module,
                    selected_modules,
                    html_enabled=False,
                )
                run_doxygen(args.doxygen, config_path, repo_root, args.dry_run, args.verbose)

            print(f"Pass 2/{total_passes}: generating Doxygen HTML documentation")
            for module in selected_modules:
                config_path = write_config_file(
                    config_dir,
                    repo_root,
                    output_root,
                    module,
                    selected_modules,
                    html_enabled=True,
                )
                run_doxygen(args.doxygen, config_path, repo_root, args.dry_run, args.verbose)

        if sphinx_sites:
            print(f"Pass 3/{total_passes}: generating Sphinx HTML documentation")
            for site in sphinx_sites:
                sphinx_environment = build_sphinx_environment(site, sphinx_sites)
                if args.verbose or args.dry_run:
                    print(f"  {site.title}: {site.source_dir} -> {site.output_dir}")
                run_sphinx_build(
                    args.sphinx,
                    site.source_dir,
                    site.output_dir,
                    args.dry_run,
                    args.verbose,
                    sphinx_environment,
                )

        if not args.dry_run:
            write_landing_page(output_root, selected_modules, sphinx_sites)
            print(f"Landing page: {output_root / 'index.html'}")

        return 0
    except (RuntimeError, OSError, subprocess.CalledProcessError) as exc:
        print(f"error: {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
