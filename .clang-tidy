---
# Cross-platform clang-tidy config for C++17
# Targets: Windows (MSVC/LLP64), macOS (Apple Clang/LP64), Linux (GCC+Clang/LP64)

Checks: >
  -*,

  clang-diagnostic-*,
  clang-analyzer-*,

  bugprone-*,
  -bugprone-easily-swappable-parameters,

  cppcoreguidelines-*,
  -cppcoreguidelines-avoid-magic-numbers,
  -cppcoreguidelines-pro-bounds-array-to-pointer-decay,
  -cppcoreguidelines-owning-memory,

  modernize-*,
  -modernize-use-trailing-return-type,
  -modernize-use-constraints,
  -modernize-use-designated-initializers,
  -modernize-use-integer-sign-comparison,
  -modernize-use-ranges,
  -modernize-use-starts-ends-with,
  -modernize-use-std-bit,
  -modernize-use-std-format,
  -modernize-use-std-numbers,
  -modernize-use-std-print,
  -modernize-use-using,

  performance-*,

  readability-*,
  -readability-magic-numbers,
  -readability-identifier-length,

  cert-*,

  misc-*,
  -misc-non-private-member-variables-in-classes,

  portability-*,
  -portability-simd-intrinsics,

  concurrency-*,

  # -- Cross-platform critical checks (explicit enables) --

  # Narrowing conversions: catches long/int size mismatches across LLP64 (Win) vs LP64 (Linux/macOS)
  bugprone-narrowing-conversions,
  cppcoreguidelines-narrowing-conversions,

  # Signed/unsigned mismatches: MSVC warns on these by default (C4018, C4244, C4267)
  bugprone-signed-char-misuse,
  bugprone-implicit-widening-of-multiplication-result,
  bugprone-misplaced-widening-cast,

  # Catches sizeof(long), sizeof(pointer) assumptions that differ across platforms
  bugprone-sizeof-expression,

  # MSVC, GCC, and Clang disagree on implicit conversion warnings
  bugprone-argument-comment,

  # Macro hygiene: platform #ifdef blocks are error-prone
  bugprone-macro-parentheses,
  bugprone-macro-repeated-side-effects,

  # Catches non-portable bitwise ops on signed types (MSVC vs GCC/Clang behavior differs)
  hicpp-signed-bitwise,

  # ODR violations from headers: one toolchain links fine, another gets duplicate symbols
  misc-definitions-in-headers,

  # Unused includes cause different warnings/errors per platform
  misc-unused-using-decls,

  # Catches compiler extension usage that won't compile on all three targets
  cert-dcl50-cpp,

  # Catches non-portable exception handling patterns
  bugprone-exception-escape,
  bugprone-throw-keyword-missing,

  # Uninitialized members: MSVC debug fills with 0xCC, release leaves garbage — different behavior per platform
  cppcoreguidelines-pro-type-member-init,

  # Virtual dispatch in constructors/destructors: subtle ABI differences across compilers
  clang-analyzer-optin.cplusplus.VirtualCall,

  # Thread safety: platform threading models differ
  bugprone-posix-return,
  concurrency-mt-unsafe,

  # -- GCC / MSVC cross-compiler compat (added 2026-05) --
  #
  # Clang-tidy runs on the Clang frontend, so it CANNOT reproduce every
  # GCC- or MSVC-specific diagnostic. Notably, GCC's `-Wsubobject-linkage`
  # (unnamed types used in named struct/function declarations — e.g.
  # `using NAME = enum : T { ... };` as a virtual-function parameter type)
  # has no clang-tidy equivalent. The only reliable way to catch those is
  # to run an actual GCC build. The checks below cover the GCC/MSVC compat
  # issues that ARE expressible in Clang's AST.

  # Catches unions / classes with user-defined dtor but no user-defined
  # default ctor — GCC implicitly deletes the default ctor when the union
  # has a non-trivial member, then errors on `new Type{}`. MSVC behaves
  # the same way under /permissive-. Clang is lenient by default.
  cppcoreguidelines-special-member-functions,

  # Anonymous enum types aliased via `using`/`typedef` give the underlying
  # type no linkage; using one as a virtual-function parameter trips GCC's
  # -Wsubobject-linkage and MSVC's C4099. clang-tidy has no direct check
  # for this pattern — `cppcoreguidelines-use-enum-class` (already enabled
  # via cppcoreguidelines-*) is the nearest signal: it nudges toward
  # `enum class NAME : T {...}` which always has linkage. The only
  # full-coverage fix is to also run a GCC build in CI.

  # Note: every check listed in this GCC/MSVC block is already enabled via
  # the broader `cppcoreguidelines-*` / `bugprone-*` globs above. They are
  # re-stated here so the rationale comments survive, and so the WarningsAsErrors
  # section below can refer to them by name without it being non-obvious.

  # -- C++17 standard lock / typedef convention (added 2026-05) --
  #
  # The `-modernize-use-*` disables in the modernize block above keep this
  # config from ever rewriting code into a feature newer than C++17. They
  # are listed there (not here) and with NO adjacent comments on purpose:
  # the Checks string is a YAML folded scalar that clang-tidy splits ONLY on
  # commas, and not all clang-tidy versions strip `#` comments before doing
  # so (see llvm-project#64343). A comment sharing a comma-cell with a check
  # gets folded into the glob, so the disable silently no-ops. Functional
  # tokens must therefore sit alone in their cell — keep it that way.
  #
  # What each disabled check would otherwise introduce (none compile under
  # -std=c++17 on MSVC or GCC; clang-tidy also language-gates most of them,
  # so these disables are belt-and-suspenders):
  #   modernize-use-constraints             -> C++20 requires-clauses / concepts
  #   modernize-use-designated-initializers -> C++20 designated initializers
  #   modernize-use-integer-sign-comparison -> C++20 std::cmp_* (<utility>)
  #   modernize-use-ranges                  -> C++20 std::ranges
  #   modernize-use-starts-ends-with        -> C++20 std::string::starts_with/ends_with
  #   modernize-use-std-bit                 -> C++20 <bit> (bit_cast, popcount, ...)
  #   modernize-use-std-format              -> C++20 std::format
  #   modernize-use-std-numbers             -> C++20 std::numbers
  #   modernize-use-std-print               -> C++23 std::print
  #
  # modernize-use-using (typedef -> `using NAME = ...`) is disabled for two
  # reasons that are specific to this project, NOT because alias declarations
  # are unportable (they are valid C++11 and fine on all three toolchains):
  #   1. The check has a long-standing bug that mangles function-pointer
  #      typedefs (llvm-project#65055), and this codebase carries many
  #      GPU/loader function-pointer typedefs that it would corrupt.
  #   2. It can synthesize `using NAME = enum : T {...}` aliases over
  #      anonymous enums, exactly the no-linkage pattern that trips GCC's
  #      -Wsubobject-linkage and MSVC C4099 (see the GCC/MSVC block above).
  # Project convention is therefore to keep `typedef`.

WarningsAsErrors: >
  bugprone-narrowing-conversions,
  cppcoreguidelines-narrowing-conversions,
  bugprone-sizeof-expression,
  portability-*,
  bugprone-signed-char-misuse,
  hicpp-signed-bitwise,
  misc-definitions-in-headers,

  # -- GCC / MSVC compat: promote the one new compat check we added above
  #    to error. `cppcoreguidelines-pro-type-member-init` is already a
  #    project-wide rule (see Checks: above) and is NOT promoted to error
  #    here because the existing codebase has many violations; treat it
  #    as a graduated cleanup rather than a hard gate. --
  cppcoreguidelines-special-member-functions

HeaderFilterRegex: '.*'

FormatStyle: file

ExtraArgs:
  - '-std=c++17'
  - '-Wno-unknown-warning-option'

CheckOptions:
  # -- Narrowing / type-size checks --
  - key: bugprone-narrowing-conversions.WarnOnIntegerNarrowingConversion
    value: true
  - key: bugprone-narrowing-conversions.WarnOnIntegerToFloatingPointNarrowingConversion
    value: true
  - key: bugprone-narrowing-conversions.WarnOnFloatingPointNarrowingConversion
    value: true
  - key: bugprone-signed-char-misuse.CharTypdefsToIgnore
    value: ''
  - key: bugprone-signed-char-misuse.DiagnoseSignedUnsignedCharComparisons
    value: true
  - key: bugprone-implicit-widening-of-multiplication-result.UseCXXStaticCastsInCppSources
    value: true

  # -- Modernize --
  - key: modernize-use-nullptr.NullMacros
    value: 'NULL'
  - key: modernize-loop-convert.NamingStyle
    value: CamelCase
  - key: modernize-loop-convert.MinConfidence
    value: reasonable

  # -- Naming conventions --
  - key: readability-identifier-naming.ClassCase
    value: CamelCase
  - key: readability-identifier-naming.StructCase
    value: CamelCase
  - key: readability-identifier-naming.FunctionCase
    value: camelBack
  # Static methods are PascalCase, matching the Create() factory convention
  # (AQContext::Create, Scene::Create, ...). NOTE: clang-tidy spells PascalCase
  # as "CamelCase"; "camelBack" above is camelCase. Instance methods have no
  # MethodCase override, so they keep FunctionCase (camelBack).
  - key: readability-identifier-naming.ClassMethodCase
    value: CamelCase
  - key: readability-identifier-naming.VariableCase
    value: camelBack
  - key: readability-identifier-naming.MemberCase
    value: camelBack
  - key: readability-identifier-naming.ParameterCase
    value: camelBack
  - key: readability-identifier-naming.NamespaceCase
    value: CamelCase
  - key: readability-identifier-naming.EnumCase
    value: CamelCase
  - key: readability-identifier-naming.EnumConstantCase
    value: CamelCase
  - key: readability-identifier-naming.ConstexprVariableCase
    value: CamelCase
  - key: readability-identifier-naming.GlobalConstantCase
    value: UPPER_CASE
  - key: readability-identifier-naming.MacroDefinitionCase
    value: UPPER_CASE
  - key: readability-identifier-naming.TypeAliasCase
    value: CamelCase
  - key: readability-identifier-naming.TypedefCase
    value: CamelCase
  - key: readability-identifier-naming.TemplateParameterCase
    value: CamelCase

  # -- Complexity / readability --
  - key: readability-function-cognitive-complexity.Threshold
    value: 25

  # -- Special member functions --
  - key: cppcoreguidelines-special-member-functions.AllowSoleDefaultDtor
    value: true
  - key: cppcoreguidelines-explicit-virtual-functions.IgnoreDestructors
    value: true
  - key: cppcoreguidelines-non-private-member-variables-in-classes.IgnoreClassesWithAllMemberVariablesBeingPublic
    value: true

  # -- Member initialization (cross-platform UB prevention) --
  - key: cppcoreguidelines-pro-type-member-init.IgnoreArrays
    value: false
  - key: cppcoreguidelines-pro-type-member-init.UseAssignment
    value: false

  # -- Performance --
  - key: performance-move-const-arg.CheckTriviallyCopyableMove
    value: false

  # -- Misc --
  - key: misc-unused-parameters.StrictMode
    value: false
  - key: cert-dcl16-c.NewSuffixes
    value: 'L;LL;LU;LLU'

  # -- Signed bitwise (portability) --
  - key: hicpp-signed-bitwise.IgnorePositiveIntegerLiterals
    value: true
...
