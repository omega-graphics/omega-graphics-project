{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Configure CMake (wtk)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-B", "${workspaceFolder}/build",
        "-S", "${workspaceFolder}",
        "-G", "Ninja",
        "-DCMAKE_BUILD_TYPE=Debug"
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "Build EllipsePathCompositorTest",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build", "${workspaceFolder}/build",
        "--target", "EllipsePathCompositorTest"
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always" }
    }
  ]
}
