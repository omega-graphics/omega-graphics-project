{
    "variables":{
         "third_party_dest":"./deps",
         "pcre2_version":"10.47",
         "strawberry_perl_version":"5.40.2.2",
         "strawberry_perl_release_dir":"SP_54022_64bit",
         "strawberry_perl_archive":"strawberry-perl-$(strawberry_perl_version)-64bit-portable.zip"
    },
    "dependencies":[
         {
            "name":"pcre2",
            "type":"archive",
            "url":"https://github.com/PCRE2Project/pcre2/releases/download/pcre2-$(pcre2_version)/pcre2-$(pcre2_version).zip",
            "dest":"$(third_party_dest)/pcre2/code",
            "expected_root":"pcre2-$(pcre2_version)",
            "exports":{
                "source_root":"$(third_party_dest)/pcre2/code/pcre2-$(pcre2_version)"
            }
         },
         {
            "name":"openssl",
            "type":"git",
            "url":"https://github.com/openssl/openssl.git",
            "dest":"$(third_party_dest)/openssl/code"
         },
         {
            "name":"strawberry-perl",
            "type":"tool",
            "platforms":["windows"],
            "source":{
                "type":"archive",
                "url":"https://downloads.sourceforge.net/project/perl-dist-strawberry.mirror/$(strawberry_perl_release_dir)/$(strawberry_perl_archive)",
                "archive_name":"$(strawberry_perl_archive)",
                "dest":"$(third_party_dest)/strawberry-perl"
            },
            "exports":{
                "perl":"$(third_party_dest)/strawberry-perl/perl/bin/perl.exe"
            }
         },
         {
            "name":"rapidjson",
            "type":"git",
            "url":"https://github.com/Tencent/rapidjson.git",
            "dest":"$(third_party_dest)/rapidjson"
        }
    ]
}
