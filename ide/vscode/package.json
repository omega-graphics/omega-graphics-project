{
    "name": "omega-graphics-vscode-extension",
    "displayName": "Omega Graphics VSCode Extension",
    "description": "The official Omega Graphics extension for VSCode",
    "version": "0.1.0",
    "author": "Omega Graphics",
    "license": "SEE LICENSE IN ../../LICENSE",
    "repository": {
        "url": "https://github.com/omega-graphics/omega-graphics-project"
    },
    "publishConfig": {
        "access": "public"
    },
    "publisher": "unpublished",
    "engines": {
        "vscode": "^1.91.0"
    },
    "main": "./out/extension.js",
    "activationEvents": [
        "onLanguage:omegasl"
    ],
    "contributes": {
        "languages": [
            {
                "id": "omegasl",
                "aliases": [
                    "OmegaSL",
                    "omegasl"
                ],
                "extensions": [
                    ".omegasl",
                    ".omegaslh"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "omegasl",
                "scopeName": "source.omegasl",
                "path": "./syntaxes/OmegaSL.tmLanguage.json"
            }
        ],
        "configuration": {
            "title": "OmegaSL",
            "properties": {
                "omegasl.lspServerPath": {
                    "type": "string",
                    "default": "",
                    "description": "Absolute path to the omegasl-lsp server binary. Leave empty to disable LSP features (syntax highlighting only)."
                },
                "omegasl.lspServerArgs": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "Extra command-line arguments passed to omegasl-lsp."
                },
                "omegasl.trace.server": {
                    "type": "string",
                    "enum": [
                        "off",
                        "messages",
                        "verbose"
                    ],
                    "default": "off",
                    "description": "Trace LSP communication between VSCode and omegasl-lsp."
                }
            }
        }
    },
    "scripts": {
        "build:grammar": "node ./scripts/build-grammar.js",
        "precompile": "npm run build:grammar",
        "compile": "rollup -c",
        "watch": "rollup -c -w",
        "prevscode:prepublish": "npm run build:grammar",
        "vscode:prepublish": "npm run compile",
        "publish": "vsce package"
    },
    "dependencies": {
        "vscode-languageclient": "^10.1.0"
    },
    "devDependencies": {
        "@rollup/plugin-commonjs": "^29.0.3",
        "@rollup/plugin-json": "^6.1.0",
        "@rollup/plugin-node-resolve": "^16.0.3",
        "@rollup/plugin-typescript": "^12.3.0",
        "@types/node": "^18.0.0",
        "@types/vscode": "^1.75.0",
        "rollup": "^4.62.2",
        "tslib": "^2.8.1",
        "typescript": "^5.3.0",
        "vsce": "^2.15.0"
    }
}
