import "fs"

var gradle_prog = find_program(cmd:"gradle")

func AndroidLib(name,source_dir) {
	var lib = JarLib(name:name,source_dir:source_dir)
	lib.maven_repos = ["google()","mavenCentral()"]
	return lib
}

func AndroidApp(name,source_dir) {
	var app = JarExe(name:name,source_dir:source_dir)
	app.maven_repos = ["google()","mavenCentral()"]
	return app
}
