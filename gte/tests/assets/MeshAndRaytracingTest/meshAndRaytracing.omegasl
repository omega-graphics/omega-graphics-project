// MeshAndRaytracingTest shader pair.
//
// Mesh stage: drives a `GEMeshAsset`-loaded mesh through the D3D12 mesh
// shader. Each mesh threadgroup is responsible for ONE triangle of the
// source FBX — the dispatch count on the C++ side is `vertexCount / 3`.
// Per-triangle dispatch is the trivial integration with `GEMeshAsset`
// (it produces a flat vertex buffer with no index buffer today; every
// 3 consecutive vertices form a triangle). Real meshlet partitioning
// — packing 64+ verts and 124+ primitives per threadgroup, the
// performance win mesh shaders are designed for — is a follow-up that
// needs a CPU-side meshlet builder we don't have yet.
//
// Vertex layout matches `GEMeshDescriptor::attributes =
// GEMeshAttrPosition` (Position only).
//
// The buffer's element stride is NOT 12 bytes on every backend, and this
// comment used to claim it was ("a lone float3 needs no padding"). It
// does: under std430 a `float3` has a 16-byte base alignment, so this
// struct's array stride is 16 — the compiled SPIR-V decorates it
// `ArrayStride = 16`. D3D12's scalar StructuredBuffer really is 12 and
// Metal's simd_float3 is 16. Nothing here has to care, because the CPU
// side no longer hand-sums the stride: `geMeshStrideFor` asks
// `omegaSLStructStride` for whatever the active backend uses, and the
// loader re-lays the vertex stream into that layout before upload. When
// they disagreed, the GPU read each vertex 4 bytes further off than the
// last and the mesh came out shredded.
//
// Why `: TexCoord` (not `: Color(N)`) for the inter-stage color: see
// the prior revision of this file in git — `Color(N)` is OmegaSL's
// fragment-output slot and lowers to HLSL `SV_Target<N>`, which DXC
// rejects on a struct field consumed by a fragment shader as input.
//
// The shader-side feature gate (`#requires(MESH_SHADERS)`) makes the
// runtime loader reject this library cleanly on devices that lack
// GTEDEVICE_FEATURE_MESH_SHADER — matches how the C++ side of the test
// reads `features.hasFeature(...)`.
//
// The MVP arrives as a push constant (`constant<T>` + `[in pc]`, the
// same shape as kreate's Phase1Basic.omegasl). It is composed on the
// CPU by `GESpace::objectTransform()`: the mesh's vertex buffer stays
// in the FBX's own local units — GESpace never re-bakes geometry — and
// this one matrix carries it local → space → NDC. Without it the raw
// FBX coordinates land outside the clip volume and nothing draws, which
// is precisely what this test used to do.

#requires(MESH_SHADERS)

struct VertexIn {
    float3 pos;
};

// Local → NDC for the placed mesh, straight from GESpace::objectTransform().
// Column-major, matching FMatrix<4,4>'s storage, so the C++ side flattens it
// column by column with no transpose.
//
// `triCount` rides along because the AMPLIFICATION stage (below) needs it: the
// last batch of triangles is almost never a full batch, and dispatching a full
// batch anyway would run mesh threadgroups off the end of the vertex buffer.
struct MeshTransform {
    float4x4 mvp;
    uint     triCount;
};

// The payload the amplification stage hands each mesh threadgroup it launches.
// A plain (non-`internal`) struct: it carries no interstage semantics, it is
// just a block of workgroup-shared data crossing the stage boundary.
struct MeshletBatch {
    uint baseTriangle;
};

constant<MeshTransform> pc      : 0;
buffer<VertexIn>        vertBuf : 1;

struct MeshletVertex internal {
    float4 pos   : Position;
    float4 color : TexCoord;
};

// How many triangles one amplification threadgroup is responsible for.
// The C++ side dispatches ceil(triCount / 32) of them.
//
// This is what mesh shaders are actually for: instead of the host issuing one
// dispatch per triangle, it issues one per BATCH and the GPU decides how much
// work each batch is worth. Here the decision is only "clamp the tail", but it
// is the same hook a real culler would use — the amplification stage is where
// you drop meshlets that face away or fall outside the frustum, and the mesh
// threadgroups for them are then never launched at all.

// One amplification threadgroup per 32-triangle batch. Single-threaded (x=1)
// so the payload write needs no cross-thread coordination.
[in pc]
amplification(x=1, y=1, z=1)
void ampFunc(uint3 gid : ThreadGroupID,
             out payload MeshletBatch p){
    uint base = gid.x * 32u;
    p.baseTriangle = base;

    // The tail batch is short. `base` is always < triCount (the host dispatches
    // exactly ceil(triCount/32) groups), so this subtraction cannot underflow.
    uint remaining = pc.triCount - base;
    uint count = remaining < 32u ? remaining : 32u;

    // Must be the final statement — GLSL lowers this to EmitMeshTasksEXT, which
    // terminates the task shader.
    dispatchMesh(count, 1u, 1u, p);
}

// `gid.x` is the CHILD index within the grid this shader's amplification stage
// dispatched — 0..31 within one batch — NOT a global triangle index. Recovering
// the global index from the payload is the entire point of the payload.
[in pc, in vertBuf]
mesh(max_vertices=3, max_primitives=1, topology=triangle)
void meshFunc(uint3 gid : ThreadGroupID,
              in payload MeshletBatch p,
              out vertices MeshletVertex verts[3],
              out indices  uint3         tris[1]){
    uint tri  = p.baseTriangle + gid.x;
    uint base = tri * 3u;

    // Cycle through a small palette by triangle index so adjacent
    // triangles have visibly distinct colors — gives a faceted look
    // without per-vertex normals. The hue ramp here is intentionally
    // low-saturation so a moderately complex FBX (a few hundred
    // triangles) does not turn into noise; the orange-ish base tint
    // matches the racket's intended look without depending on the
    // FBX's diffuse texture.
    //
    // Keyed on the payload-derived GLOBAL triangle index, not on gid.x: if the
    // payload were dropped, every batch would tint identically from 0..31 and
    // the model would come out in 32-triangle stripes instead of a smooth ramp.
    float tintShift = float(tri % 7u) / 7.0;
    float4 tint = float4(0.55 + 0.30 * tintShift,
                         0.35 + 0.20 * tintShift,
                         0.10 + 0.05 * tintShift,
                         1.0);

    verts[0].pos   = pc.mvp * float4(vertBuf[base + 0u].pos, 1.0);
    verts[0].color = tint;
    verts[1].pos   = pc.mvp * float4(vertBuf[base + 1u].pos, 1.0);
    verts[1].color = tint;
    verts[2].pos   = pc.mvp * float4(vertBuf[base + 2u].pos, 1.0);
    verts[2].color = tint;

    tris[0] = uint3(0, 1, 2);
}

fragment float4 fragFunc(MeshletVertex raster){
    return raster.color;
}
