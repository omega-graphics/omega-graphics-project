// MeshAndRaytracingTest — G-buffer raster + ray-traced shadows.
//
// Every stage the test needs lives in this ONE translation unit, so omegaslc emits
// a single .omegasllib and the test loads exactly one library:
//
//   1. primVert / primFrag  — the TE 3D primitives (Sphere, Cylinder, Cone, Torus,
//                             ...) placed by GESpace. Their vertices are
//                             Position+Normal, because GESpace now hands back the
//                             normals TE already generated (Raytracing plan §7-V.a)
//                             instead of dropping them on the floor.
//   2. ampFunc / meshFunc / — the GEMeshAsset-loaded FBX, through the mesh-shader
//      meshFrag               pipeline. Its vertex buffer is Position-only, so the
//                             mesh stage derives a FLAT face normal per triangle.
//   3. shadowKernel         — the point of the test. An inline ray-query compute
//                             pass that reads the G-buffer, casts one shadow ray per
//                             pixel at the light, and shades the result.
//   4. compositeVert /      — fullscreen pass resolving the lit image onto the
//      compositeFrag          drawable.
//
// Why a G-buffer: ray-traced shadows need the WORLD POSITION and NORMAL of whatever
// is visible at each pixel, and neither survives an 8-bit unorm drawable —
// positions are unbounded and normals are signed. So the raster half renders
// offscreen into float targets (RGBA32Float position, RGBA16Float normal, RGBA8
// albedo) with a real depth buffer, and the drawable only ever receives the final
// resolved image. That is also the engine-wide standard: a swapchain has no depth
// buffer on any API, so 3D renders offscreen and is blitted/resolved.

#requires(RAYTRACING)
#requires(MESH_SHADERS)

// ── Shared G-buffer layout ──────────────────────────────────────────────────
//
// Color(0) worldPos : xyz = world position, w = COVERAGE (1 = geometry, 0 = sky).
//   The coverage flag is what the shadow kernel tests to skip background pixels.
//   Without it there is no way to tell "a surface at the world origin" from
//   "nothing was drawn here", and the background would trace rays from (0,0,0).
// Color(1) normal   : xyz = world normal. Signed — hence a float format.
// Color(2) albedo   : base color.
struct GBuffer internal {
    float4 worldPos : Color(0);
    float4 normal   : Color(1);
    float4 albedo   : Color(2);
};

// Per-object transforms. `mvp` is local→NDC (composed by GESpace::objectTransform);
// `model` is local→WORLD.
//
// The G-buffer stores WORLD space because the acceleration structure the shadow
// rays are traced against is built in world space. If the two disagreed, every
// shadow would land somewhere else entirely.
//
// `normalMat` is the inverse-transpose of `model`. Rotating a normal by `model`
// directly is only correct under uniform scale; the moment an object is scaled
// non-uniformly it skews normals off the surface and the lighting goes quietly
// wrong everywhere.
struct ObjectXform {
    float4x4 mvp;
    float4x4 model;
    float4x4 normalMat;
    float4   albedo;
    uint     triCount;   // amplification stage only
};

constant<ObjectXform> pc : 0;

// ── 1. TE primitives — Position + Normal ────────────────────────────────────

struct PrimVertex {
    float3 pos;
    float3 normal;
};

struct PrimRaster internal {
    float4 pos      : Position;
    float4 worldPos : TexCoord;
    float4 normal   : Color;
};

buffer<PrimVertex> primVerts : 1;

[in pc, in primVerts]
vertex PrimRaster primVert(uint vid : VertexID){
    PrimVertex v = primVerts[vid];

    PrimRaster r;
    r.pos      = pc.mvp * float4(v.pos, 1.0);
    r.worldPos = pc.model * float4(v.pos, 1.0);
    r.normal   = pc.normalMat * float4(v.normal, 0.0);
    return r;
}

[in pc]
fragment GBuffer primFrag(PrimRaster raster){
    float3 n = normalize(float3(raster.normal[0], raster.normal[1], raster.normal[2]));

    GBuffer o;
    o.worldPos = float4(raster.worldPos[0], raster.worldPos[1], raster.worldPos[2], 1.0);
    o.normal   = float4(n, 0.0);
    o.albedo   = pc.albedo;
    return o;
}

// ── 2. FBX mesh — Position only, flat normals ───────────────────────────────

struct MeshVertexIn {
    float3 pos;
};

struct MeshletBatch {
    uint baseTriangle;
};

struct MeshRaster internal {
    float4 pos      : Position;
    float4 worldPos : TexCoord;
    float4 normal   : Color;
};

buffer<MeshVertexIn> vertBuf : 2;

// One amplification threadgroup per 32-triangle batch. The tail batch is clamped so
// mesh threadgroups are never launched past the end of the vertex buffer.
[in pc]
amplification(x=1, y=1, z=1)
void ampFunc(uint3 gid : ThreadGroupID,
             out payload MeshletBatch p){
    uint base = gid[0] * 32u;
    p.baseTriangle = base;

    uint remaining = pc.triCount - base;
    uint count = remaining < 32u ? remaining : 32u;

    // Must be the final statement — GLSL lowers this to EmitMeshTasksEXT, which
    // terminates the task shader.
    dispatchMesh(count, 1u, 1u, p);
}

// GEMeshAsset produces a Position-only vertex buffer, so there are no authored
// normals to interpolate. The face normal is derived here from the triangle's own
// edges. That yields a faceted look — correct, just not smooth — which is all the
// shadow term needs, since it only asks which way the surface points.
[in pc, in vertBuf]
mesh(max_vertices=3, max_primitives=1, topology=triangle)
void meshFunc(uint3 gid : ThreadGroupID,
              in payload MeshletBatch p,
              out vertices MeshRaster verts[3],
              out indices  uint3      tris[1]){
    uint tri  = p.baseTriangle + gid[0];
    uint base = tri * 3u;

    float3 p0 = vertBuf[base + 0u].pos;
    float3 p1 = vertBuf[base + 1u].pos;
    float3 p2 = vertBuf[base + 2u].pos;

    float3 faceN = normalize(cross(p1 - p0, p2 - p0));
    float4 nWorld = pc.normalMat * float4(faceN, 0.0);

    verts[0].pos      = pc.mvp * float4(p0, 1.0);
    verts[0].worldPos = pc.model * float4(p0, 1.0);
    verts[0].normal   = nWorld;

    verts[1].pos      = pc.mvp * float4(p1, 1.0);
    verts[1].worldPos = pc.model * float4(p1, 1.0);
    verts[1].normal   = nWorld;

    verts[2].pos      = pc.mvp * float4(p2, 1.0);
    verts[2].worldPos = pc.model * float4(p2, 1.0);
    verts[2].normal   = nWorld;

    tris[0] = uint3(0, 1, 2);
}

[in pc]
fragment GBuffer meshFrag(MeshRaster raster){
    float3 n = normalize(float3(raster.normal[0], raster.normal[1], raster.normal[2]));

    GBuffer o;
    o.worldPos = float4(raster.worldPos[0], raster.worldPos[1], raster.worldPos[2], 1.0);
    o.normal   = float4(n, 0.0);
    o.albedo   = pc.albedo;
    return o;
}

// ── 3. Ray-traced shadows (the point of the test) ───────────────────────────

struct ShadowParams {
    float4 lightPos;   // xyz = light position (world), w = light RADIUS
    float4 ambient;    // rgb = ambient term, w = shadow strength (0..1)
    float4 dims;       // xy = G-buffer extent in pixels
};

// Shadow rays per pixel. A single ray gives a hard, stencil-sharp edge — which is
// what a POINT light produces, and it is a giveaway that the "light" has no size.
// Sampling a light of nonzero radius over many rays is what produces a real
// penumbra: pixels that see part of the light are partly lit.
//
// This is the ray budget. 32/pixel at 800x600 is ~15M shadow rays a frame, which is
// nothing for the hardware this targets.
#define SHADOW_SAMPLES 32u

// Cheap per-pixel hash. Deterministic, so the image does not shimmer, but decorrelated
// enough between neighbouring pixels that the sample pattern reads as soft noise
// rather than as banding.
float hash1(float2 p){
    return frac(sin(dot(p, float2(127.1, 311.7))) * 43758.5453);
}

constant<ShadowParams> sp : 3;

AccelerationStructure scene : 4;
texture2d gWorldPos : 5;
texture2d gNormal   : 6;
texture2d gAlbedo   : 7;
texture2d litOut    : 8;

[in sp, in scene, in gWorldPos, in gNormal, in gAlbedo, out litOut]
compute(x=8, y=8, z=1)
void shadowKernel(uint3 tid : GlobalThreadID){
    int px = (int)tid[0];
    int py = (int)tid[1];

    if(px >= (int)sp.dims[0]){
        return;
    }
    if(py >= (int)sp.dims[1]){
        return;
    }

    float4 wp = read(gWorldPos, int2(px, py));

    // Coverage: nothing was rasterized here, so paint the sky and DO NOT trace.
    // Tracing background pixels would cast rays from the world origin and speckle
    // the sky with meaningless hits.
    if(wp[3] < 0.5){
        write(litOut, int2(px, py), float4(0.05, 0.06, 0.09, 1.0));
        return;
    }

    float3 P = float3(wp[0], wp[1], wp[2]);

    float4 nRaw = read(gNormal, int2(px, py));
    float3 N = normalize(float3(nRaw[0], nRaw[1], nRaw[2]));

    float4 albedo = read(gAlbedo, int2(px, py));

    float3 toLight = float3(sp.lightPos[0], sp.lightPos[1], sp.lightPos[2]) - P;
    float lightDist = length(toLight);
    float3 L = normalize(toLight);

    float ndotl = dot(N, L);
    if(ndotl < 0.0){
        ndotl = 0.0;
    }

    // ── the shadow ray ──
    //
    // The origin is pushed off the surface along the normal first. Without that
    // bias the ray starts exactly ON the surface it came from and immediately
    // re-hits its own triangle at t≈0, so every lit surface shadows itself and the
    // whole image collapses to black. That is the classic shadow-acne failure and
    // it is worth the one line to avoid.
    //
    // RAY_FLAG_TERMINATE_ON_FIRST_HIT is exactly what a shadow ray wants: we only
    // need to know whether ANYTHING blocks the light, never which thing or how far,
    // so traversal can stop at the first hit instead of searching for the closest.
    //
    // tmax is clamped to the light distance so geometry BEHIND the light cannot
    // occlude it.
    float3 origin = P + N * 0.02;
    float radius = sp.lightPos[3];

    // Build a basis on the light plane so the jitter spreads ACROSS the light disc
    // rather than along the ray (which would just move the light nearer/further and
    // change nothing about occlusion).
    float3 up = float3(0.0, 1.0, 0.0);
    if(abs(L[1]) > 0.95){
        up = float3(1.0, 0.0, 0.0);
    }
    float3 tangent = normalize(cross(up, L));
    float3 bitangent = cross(L, tangent);

    float2 seed = float2((float)px, (float)py);
    float visible = 0.0;

    for(uint i = 0u; i < SHADOW_SAMPLES; i = i + 1u){
        float fi = (float)i;
        // Two decorrelated randoms per sample, jittered per pixel.
        float r1 = hash1(seed + float2(fi * 1.37, fi * 2.71));
        float r2 = hash1(seed + float2(fi * 3.14 + 11.0, fi * 0.77 + 5.0));

        // Uniform point on a disc: sqrt(r) keeps samples from bunching at the centre.
        float rad = radius * sqrt(r1);
        float ang = 6.2831853 * r2;
        float3 jitter = tangent * (rad * cos(ang)) + bitangent * (rad * sin(ang));

        float3 target = float3(sp.lightPos[0], sp.lightPos[1], sp.lightPos[2]) + jitter;
        float3 dir = target - origin;
        float dist = length(dir);
        dir = normalize(dir);

        Ray shadowRay;
        shadowRay.origin    = origin;
        shadowRay.direction = dir;
        shadowRay.tmin      = 0.0;
        shadowRay.tmax      = dist - 0.02;

        // TERMINATE_ON_FIRST_HIT: a shadow ray only asks "is ANYTHING in the way",
        // never which thing or how far, so traversal stops at the first hit instead
        // of hunting for the closest. Over 32 rays a pixel that is the difference
        // between a real cost and a silly one.
        RayHit hit = intersect(scene, shadowRay, 255, RAY_FLAG_TERMINATE_ON_FIRST_HIT);
        if(!hit.committed){
            visible = visible + 1.0;
        }
    }

    visible = visible / (float)SHADOW_SAMPLES;

    // Fully occluded -> (1 - strength); fully visible -> 1. Partially occluded
    // pixels land in between, and THAT is the penumbra.
    float shadow = (1.0 - sp.ambient[3]) + sp.ambient[3] * visible;

    float3 amb = float3(sp.ambient[0], sp.ambient[1], sp.ambient[2]);
    float lit = ndotl * shadow;
    float3 base = float3(albedo[0], albedo[1], albedo[2]);
    float3 color = base * (amb + float3(lit, lit, lit));

    write(litOut, int2(px, py), float4(color, 1.0));
}

// ── 4. Composite to the drawable ────────────────────────────────────────────

struct FSRaster internal {
    float4 pos : Position;
    float2 uv  : TexCoord;
};

static sampler2d litSampler(filter=linear, address_mode=clamp_to_edge);
texture2d litTex : 9;

// A fullscreen TRIANGLE, not a quad: three vertices, no vertex buffer, no index
// buffer — the positions come from the vertex id alone. Written without bit tricks
// so it reads identically on every backend.
vertex FSRaster compositeVert(uint vid : VertexID){
    float x = 0.0;
    float y = 0.0;
    if(vid == 1u){
        x = 2.0;
    }
    if(vid == 2u){
        y = 2.0;
    }

    FSRaster r;
    r.uv  = float2(x, y);
    r.pos = float4(x * 2.0 - 1.0, 1.0 - y * 2.0, 0.0, 1.0);
    return r;
}

[in litTex, in litSampler]
fragment float4 compositeFrag(FSRaster raster){
    return sample(litSampler, litTex, raster.uv);
}
