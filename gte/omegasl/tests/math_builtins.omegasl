
struct MathData {
    float4 value;
};

buffer<MathData> src : 0;
buffer<MathData> dst : 1;

[in src, out dst]
compute(x=1,y=1,z=1)
void test_trig(uint3 tid : GlobalThreadID){
    float a = src[0].value[0];
    float s = sin(a);
    float c = cos(a);
    float t = tan(a);
    dst[0].value = make_float4(s, c, t, 0.0);
}

[in src, out dst]
compute(x=1,y=1,z=1)
void test_inverse_trig(uint3 tid : GlobalThreadID){
    float a = src[0].value[0];
    float as = asin(a);
    float ac = acos(a);
    float at = atan(a);
    float at2 = atan2(a, 1.0);
    dst[0].value = make_float4(as, ac, at, at2);
}

[in src, out dst]
compute(x=1,y=1,z=1)
void test_power_exp(uint3 tid : GlobalThreadID){
    float a = src[0].value[0];
    float sq = sqrt(a);
    float p = pow(a, 2.0);
    float e = exp(a);
    float l = log(a);
    dst[0].value = make_float4(sq, p, e, l);
}

[in src, out dst]
compute(x=1,y=1,z=1)
void test_rounding(uint3 tid : GlobalThreadID){
    float a = src[0].value[0];
    float ab = abs(a);
    float fl = floor(a);
    float cl = ceil(a);
    float rn = round(a);
    dst[0].value = make_float4(ab, fl, cl, rn);
}

[in src, out dst]
compute(x=1,y=1,z=1)
void test_interpolation(uint3 tid : GlobalThreadID){
    float a = src[0].value[0];
    float b = src[0].value[1];
    float t = src[0].value[2];
    float mn = min(a, b);
    float mx = max(a, b);
    float cl = clamp(t, 0.0, 1.0);
    float lr = lerp(a, b, t);
    dst[0].value = make_float4(mn, mx, cl, lr);
}

[in src, out dst]
compute(x=1,y=1,z=1)
void test_vector_math(uint3 tid : GlobalThreadID){
    float3 v = make_float3(src[0].value[0], src[0].value[1], src[0].value[2]);
    float len = length(v);
    float3 n = normalize(v);
    float fr = frac(src[0].value[0]);
    dst[0].value = make_float4(len, n[0], n[1], fr);
}
