
struct Particle {
    float4 position;
    float4 velocity;
};

struct SimParams {
    float4 gravity;
    float4 wind;
    float4 bounds;
    float4 config;
};

buffer<Particle> particles : 0;
buffer<SimParams> simParams : 1;

float apply_damping(float vel, float factor){
    return vel * factor;
}

[in simParams, inout particles]
compute(x=64,y=1,z=1)
void update_particles(uint3 tid : GlobalThreadID){
    uint count = (uint)simParams[0].config[0];
    float dt = simParams[0].config[1];
    float damping = simParams[0].config[2];
    float bounciness = simParams[0].config[3];

    uint idx = tid[0];
    if(idx >= count){
        return;
    }

    float px = particles[idx].position[0];
    float py = particles[idx].position[1];
    float pz = particles[idx].position[2];
    float life = particles[idx].position[3];

    float vx = particles[idx].velocity[0];
    float vy = particles[idx].velocity[1];
    float vz = particles[idx].velocity[2];
    float mass = particles[idx].velocity[3];

    float gx = simParams[0].gravity[0];
    float gy = simParams[0].gravity[1];
    float gz = simParams[0].gravity[2];

    float wx = simParams[0].wind[0];
    float wy = simParams[0].wind[1];
    float wz = simParams[0].wind[2];
    float windStr = simParams[0].wind[3];

    float ax = gx + wx * windStr / mass;
    float ay = gy + wy * windStr / mass;
    float az = gz + wz * windStr / mass;

    vx = apply_damping(vx + ax * dt, damping);
    vy = apply_damping(vy + ay * dt, damping);
    vz = apply_damping(vz + az * dt, damping);

    px = px + vx * dt;
    py = py + vy * dt;
    pz = pz + vz * dt;

    float minX = simParams[0].bounds[0];
    float minY = simParams[0].bounds[1];
    float maxX = simParams[0].bounds[2];
    float maxY = simParams[0].bounds[3];

    if(py < minY){
        py = minY;
        vy = abs(vy) * bounciness;
    }
    if(py > maxY){
        py = maxY;
        vy = -abs(vy) * bounciness;
    }
    if(px < minX){
        px = minX;
        vx = abs(vx) * bounciness;
    }
    if(px > maxX){
        px = maxX;
        vx = -abs(vx) * bounciness;
    }

    life = life - dt;

    particles[idx].position = make_float4(px, py, pz, life);
    particles[idx].velocity = make_float4(vx, vy, vz, mass);
}

[in simParams, inout particles]
compute(x=64,y=1,z=1)
void emit_particles(uint3 tid : GlobalThreadID){
    uint count = (uint)simParams[0].config[0];
    float emitSpeed = simParams[0].config[1];

    uint idx = tid[0];
    if(idx >= count){
        return;
    }

    float life = particles[idx].position[3];

    if(life <= 0.0){
        float angle = (float)idx * 0.618033 * 6.28318;
        float speed = emitSpeed;
        float vx = cos(angle) * speed;
        float vy = sin(angle) * speed + 2.0;
        float vz = sin(angle * 0.5) * speed * 0.3;

        particles[idx].position = make_float4(0.0, 0.0, 0.0, 3.0);
        particles[idx].velocity = make_float4(vx, vy, vz, particles[idx].velocity[3]);
    }
}
