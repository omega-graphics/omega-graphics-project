
// §6.1 — `threadgroup` is only valid inside a compute shader. Declaring
// one in a fragment shader must be rejected by Sema.

struct Raster internal {
    float4 pos : Position;
};

fragment float4 main_frag(Raster in){
    threadgroup float scratch[16];
    return float4(scratch[0], 0.0, 0.0, 1.0);
}
