// §5.3 Phase A — integer / bitfield ops: countbits / reversebits.
//   countbits(x)   — population count, returns the operand's type.
//   reversebits(x) — bit reversal, returns the operand's type.
// Covers scalar uint/int and uint4/int4 vector operands. Per backend:
//   MSL  — popcount / reverse_bits (native, T -> T).
//   GLSL — bitfieldReverse (native) / bitCount (signed result cast back).
//   HLSL — scalar-uint countbits / reversebits; signed scalars cast back,
//          vector operands expanded component-wise.

struct Data { uint4 value; };

buffer<Data> input : 0;
buffer<Data> output : 1;

[in input, out output]
compute(x=1,y=1,z=1)
void test_count_reverse_scalar(uint3 tid : GlobalThreadID){
    uint u = input[0].value[0];
    int  i = (int)input[0].value[1];

    uint cu = countbits(u);          // uint -> uint
    int  ci = countbits(i);          // int  -> int  (signed cast on HLSL)
    uint ru = reversebits(u);        // uint -> uint
    int  ri = reversebits(i);        // int  -> int

    output[0].value = uint4(cu, (uint)ci, ru, (uint)ri);
}

[in input, out output]
compute(x=1,y=1,z=1)
void test_count_reverse_vector(uint3 tid : GlobalThreadID){
    uint4 uv = input[0].value;
    int4  iv = int4((int)uv[0], (int)uv[1], (int)uv[2], (int)uv[3]);

    uint4 cu = countbits(uv);        // HLSL expands component-wise
    int4  ci = countbits(iv);
    uint4 ru = reversebits(uv);
    int4  ri = reversebits(iv);

    output[0].value = cu + ru + uint4((uint)ci.x, (uint)ci.y, (uint)ri.x, (uint)ri.y);
}

// §5.3 Phase B — firstbithigh / firstbitlow.
//   Return a signed int / intN: the zero-based index of the highest /
//   lowest set bit, or -1 when no bit is set. Normalized identically on
//   all three backends (verified by host equivalence + GPU runtime test).
[in input, out output]
compute(x=1,y=1,z=1)
void test_firstbit_scalar(uint3 tid : GlobalThreadID){
    uint u = input[0].value[0];
    int  i = (int)input[0].value[1];

    int hu = firstbithigh(u);        // uint  -> int
    int lu = firstbitlow(u);
    int hi = firstbithigh(i);        // signed operand, same normalized index
    int li = firstbitlow(i);

    output[0].value = uint4((uint)hu, (uint)lu, (uint)hi, (uint)li);
}

[in input, out output]
compute(x=1,y=1,z=1)
void test_firstbit_vector(uint3 tid : GlobalThreadID){
    uint4 uv = input[0].value;
    int4  iv = int4((int)uv[0], (int)uv[1], (int)uv[2], (int)uv[3]);

    int4 hu = firstbithigh(uv);      // uint4 -> int4
    int4 lu = firstbitlow(uv);
    int4 hi = firstbithigh(iv);
    int4 li = firstbitlow(iv);

    output[0].value = uint4((uint)hu.x, (uint)lu.y, (uint)hi.z, (uint)li.w);
}

// §5.3 Phase C — bitfieldExtract / bitfieldInsert.
//   GLSL native (bitfieldExtract/Insert), MSL native (extract_bits/insert_bits),
//   HLSL manual shift+mask (no named intrinsic). Unsigned zero-extends, signed
//   sign-extends; vector forms broadcast the scalar offset/bits.
[in input, out output]
compute(x=1,y=1,z=1)
void test_bitfield_scalar(uint3 tid : GlobalThreadID){
    uint u = input[0].value[0];
    int  i = (int)input[0].value[1];
    uint off = 4;
    uint bits = 8;

    uint eu = bitfieldExtract(u, off, bits);        // uint  -> zero-extend
    int  ei = bitfieldExtract(i, off, bits);        // int   -> sign-extend
    uint iu = bitfieldInsert(u, input[0].value[2], off, bits);

    output[0].value = uint4(eu, (uint)ei, iu, 0);
}

[in input, out output]
compute(x=1,y=1,z=1)
void test_bitfield_vector(uint3 tid : GlobalThreadID){
    uint4 uv = input[0].value;
    int4  iv = int4((int)uv[0], (int)uv[1], (int)uv[2], (int)uv[3]);
    uint off = 2;
    uint bits = 12;

    uint4 eu = bitfieldExtract(uv, off, bits);      // vector, scalar off/bits
    int4  ei = bitfieldExtract(iv, off, bits);
    uint4 iu = bitfieldInsert(uv, uv, off, bits);

    output[0].value = eu + iu + uint4((uint)ei.x, (uint)ei.y, (uint)ei.z, (uint)ei.w);
}
