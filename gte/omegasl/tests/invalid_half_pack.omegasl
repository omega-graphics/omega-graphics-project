// §5.5 Phase B — negative test for half-float pack / unpack. Multi-error:
//   (1) f16tof32 with the wrong arg count (takes exactly 1).
//   (2) f16tof32 on a float operand — operand must be uint.
//   (3) f32tof16 on a uint operand — operand must be float.
//   (4) packHalf2x16 on a float operand — operand must be float2.
//   (5) unpackHalf2x16 on a float operand — operand must be uint.

struct Data { uint4 value; };

buffer<Data> input  : 0;
buffer<Data> output : 1;

[in input, out output]
compute(x=1,y=1,z=1)
void test_bad(uint3 tid : GlobalThreadID){
    float f = (float)input[0].value[0];
    uint  u = input[0].value[1];

    float bad1 = f16tof32(u, u);            // (1) arg count
    float bad2 = f16tof32(f);                // (2) float operand
    uint  bad3 = f32tof16(u);                // (3) uint operand
    uint  bad4 = packHalf2x16(f);            // (4) scalar operand
    float2 bad5 = unpackHalf2x16(f);         // (5) float operand

    output[0].value = uint4(asuint(bad1), asuint(bad2), bad3, bad4 + asuint(bad5.x));
}
