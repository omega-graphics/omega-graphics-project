// §2a smoke test — canonical meshlet emission for the GLSL backend.
// Front-end was verified in Phase 1; this fixture pushes a real mesh
// shader through codegen and exercises the per-topology output routing
// (triangle in the main entry, line/point in the second/third).

#requires(MESH_SHADERS)

struct MeshletVertex internal {
    float4 pos : Position;
    float4 color : Color(0);
};

mesh(max_vertices=3, max_primitives=1, topology=triangle)
void mesh_triangle(uint3 tid : GlobalThreadID,
                   out vertices MeshletVertex verts[3],
                   out indices  uint3         tris[1]){
    verts[0].pos = float4(0.0, 0.0, 0.0, 1.0);
    verts[0].color = float4(1.0, 0.0, 0.0, 1.0);
    verts[1].pos = float4(1.0, 0.0, 0.0, 1.0);
    verts[1].color = float4(0.0, 1.0, 0.0, 1.0);
    verts[2].pos = float4(0.5, 1.0, 0.0, 1.0);
    verts[2].color = float4(0.0, 0.0, 1.0, 1.0);
    tris[0] = uint3(0, 1, 2);
}

mesh(max_vertices=2, max_primitives=1, topology=line)
void mesh_line(uint3 tid : GlobalThreadID,
               out vertices MeshletVertex verts[2],
               out indices  uint2         segs[1]){
    verts[0].pos = float4(0.0, 0.0, 0.0, 1.0);
    verts[0].color = float4(1.0, 1.0, 1.0, 1.0);
    verts[1].pos = float4(1.0, 1.0, 0.0, 1.0);
    verts[1].color = float4(1.0, 1.0, 1.0, 1.0);
    segs[0] = uint2(0, 1);
}

mesh(max_vertices=1, max_primitives=1, topology=point)
void mesh_point(uint3 tid : GlobalThreadID,
                out vertices MeshletVertex verts[1],
                out indices  uint          pts[1]){
    verts[0].pos = float4(0.5, 0.5, 0.0, 1.0);
    verts[0].color = float4(1.0, 1.0, 1.0, 1.0);
    pts[0] = 0;
}

// §2a follow-up — `setMeshOutputs(nv, np)` runtime form. When present the
// GLSL backend must SUPPRESS its auto-emitted locked-to-maxima
// `SetMeshOutputsEXT(<max>, <max>)` and lower the user call in place
// (GL_EXT_mesh_shader permits only one such call per shader). On HLSL/MSL
// the builtin is wired (rename / handle-call) ahead of Phase 2b/2c.
mesh(max_vertices=3, max_primitives=1, topology=triangle)
void mesh_triangle_runtime(uint3 tid : GlobalThreadID,
                           out vertices MeshletVertex verts[3],
                           out indices  uint3         tris[1]){
    setMeshOutputs(3u, 1u);
    verts[0].pos = float4(0.0, 0.0, 0.0, 1.0);
    verts[0].color = float4(1.0, 0.0, 0.0, 1.0);
    verts[1].pos = float4(1.0, 0.0, 0.0, 1.0);
    verts[1].color = float4(0.0, 1.0, 0.0, 1.0);
    verts[2].pos = float4(0.5, 1.0, 0.0, 1.0);
    verts[2].color = float4(0.0, 0.0, 1.0, 1.0);
    tris[0] = uint3(0, 1, 2);
}
