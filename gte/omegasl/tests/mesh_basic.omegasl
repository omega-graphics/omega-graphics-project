// §2a / §2b smoke test — canonical meshlet emission. GLSL was the first
// backend verified (Phase 2a); HLSL Phase 2b reuses this same fixture
// for source-only verification. Exercises the per-topology output
// routing (triangle in the main entry, line in the second).
//
// `topology=point` was dropped from this fixture in Phase 2b — Sema now
// rejects it as non-portable (HLSL SM 6.5 has no
// `[outputtopology("point")]`, only `"triangle"` and `"line"`). See
// `invalid_topology_point.omegasl` for the negative fixture that pins
// the rejection.

#requires(MESH_SHADERS)

struct MeshletVertex internal {
    float4 pos : Position;
    float4 color : Color(0);
};

mesh(max_vertices=3, max_primitives=1, topology=triangle)
void mesh_triangle(uint3 tid : GlobalThreadID,
                   out vertices MeshletVertex verts[3],
                   out indices  uint3         tris[1]){
    verts[0].pos = float4(0.0, 0.0, 0.0, 1.0);
    verts[0].color = float4(1.0, 0.0, 0.0, 1.0);
    verts[1].pos = float4(1.0, 0.0, 0.0, 1.0);
    verts[1].color = float4(0.0, 1.0, 0.0, 1.0);
    verts[2].pos = float4(0.5, 1.0, 0.0, 1.0);
    verts[2].color = float4(0.0, 0.0, 1.0, 1.0);
    tris[0] = uint3(0, 1, 2);
}

mesh(max_vertices=2, max_primitives=1, topology=line)
void mesh_line(uint3 tid : GlobalThreadID,
               out vertices MeshletVertex verts[2],
               out indices  uint2         segs[1]){
    verts[0].pos = float4(0.0, 0.0, 0.0, 1.0);
    verts[0].color = float4(1.0, 1.0, 1.0, 1.0);
    verts[1].pos = float4(1.0, 1.0, 0.0, 1.0);
    verts[1].color = float4(1.0, 1.0, 1.0, 1.0);
    segs[0] = uint2(0, 1);
}

// §2a/2b follow-up — `setMeshOutputs(nv, np)` runtime form. When present
// the backend must SUPPRESS its auto-emitted locked-to-maxima
// `SetMeshOutputsEXT` (GLSL) / `SetMeshOutputCounts` (HLSL) and lower
// the user call in place (the extension/spec permits only one such call
// per shader). MSL lowering exists but the `[[mesh]]` parameter
// materialization lands in Phase 2c.
mesh(max_vertices=3, max_primitives=1, topology=triangle)
void mesh_triangle_runtime(uint3 tid : GlobalThreadID,
                           out vertices MeshletVertex verts[3],
                           out indices  uint3         tris[1]){
    setMeshOutputs(3u, 1u);
    verts[0].pos = float4(0.0, 0.0, 0.0, 1.0);
    verts[0].color = float4(1.0, 0.0, 0.0, 1.0);
    verts[1].pos = float4(1.0, 0.0, 0.0, 1.0);
    verts[1].color = float4(0.0, 1.0, 0.0, 1.0);
    verts[2].pos = float4(0.5, 1.0, 0.0, 1.0);
    verts[2].color = float4(0.0, 0.0, 1.0, 1.0);
    tris[0] = uint3(0, 1, 2);
}
