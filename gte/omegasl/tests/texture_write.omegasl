
struct CopyParams {
    uint4 dimensions;
};

buffer<CopyParams> params : 0;
texture2d srcTex : 1;
texture2d dstTex : 2;

[in params, in srcTex, out dstTex]
compute(x=8,y=8,z=1)
void textureCopy(uint3 tid : GlobalThreadID){
    uint x = tid[0];
    uint y = tid[1];
    uint w = params[0].dimensions[0];
    uint h = params[0].dimensions[1];

    if(x >= w){
        return;
    }
    if(y >= h){
        return;
    }

    uint2 coord = make_uint2(x, y);
    float4 color = read(srcTex, coord);
    write(dstTex, coord, color);
}
