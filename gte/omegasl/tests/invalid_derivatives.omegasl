/// §5.4 — negative test for derivative builtins. Multi-error:
///   (1) ddx in a vertex shader  — derivatives are fragment-only.
///   (2) ddy of an int operand    — float scalar/vector only.
///   (3) fwidth with wrong arity  — 1-arg intrinsic.
///   (4) ddx_coarse in a compute shader — fragment-only (variant gate).

struct VertexRaster internal {
    float4 pos : Position;
};

vertex VertexRaster badDerivVert(uint vid : VertexID){
    VertexRaster r;
    // (1) Stage error — derivatives are fragment-only.
    float bad1 = ddx(0.5);
    r.pos = float4(bad1, 0.0, 0.0, 1.0);
    return r;
}

fragment float4 badDerivFrag(VertexRaster raster){
    int n = 3;
    // (2) Type error — derivative requires float scalar/vector.
    float t = ddy(n);
    // (3) Arg-count error — fwidth is 1-arg.
    float u = fwidth(0.1, 0.2);
    return float4(t, u, 0.0, 1.0);
}

struct Out { uint v; };
buffer<Out> output : 0;

[out output]
compute(x=1,y=1,z=1)
void badDerivCompute(uint3 tid : GlobalThreadID){
    // (4) Stage error — coarse/fine variants are also fragment-only.
    float bad4 = ddx_coarse(0.25);
    output[0].v = (uint)bad4;
}
