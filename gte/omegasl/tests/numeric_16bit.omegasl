/// §4.1 — 16-bit numeric types. Exercises `half`, `short`, `ushort`
/// and their 2/3/4 vector forms. The `#requires(FLOAT16)` directive
/// is what makes the GLSL backend emit
/// `#extension GL_EXT_shader_explicit_arithmetic_types_*` headers and
/// what flips the runtime feature-bit so devices without 16-bit
/// support decline cleanly.
#requires(FLOAT16)

struct VertexRaster internal {
    float4 pos : Position;
    half2  uv  : TexCoord;
};

struct HalfBundle {
    half  scale;
    half3 tint;
};

vertex VertexRaster halfVert(uint vid : VertexID){
    VertexRaster r;
    r.pos = float4(0.0, 0.0, 0.0, 1.0);
    r.uv  = make_half2(0.5, 0.5);
    return r;
}

fragment float4 halfFrag(VertexRaster raster){
    /// Half scalars — float literal coerces, suffixed `h` parses as half-typed.
    half  s   = 0.5;
    half  s2  = 1.5h;
    half2 v2  = make_half2(0.25, 0.75);
    half3 v3  = make_half3(0.1, 0.2, 0.3);
    half4 v4  = make_half4(0.0, 0.5, 1.0, 1.0);

    /// 16-bit ints. Values come from int literals (coerce) and an
    /// explicit cast that proves the cast path also trips FLOAT16.
    short  i  = -1;
    ushort u  = 7;
    short2 i2 = make_short2(-1, 2);
    ushort4 u4 = make_ushort4(0, 1, 2, 3);
    short  i_cast = (short)42;

    /// Struct that contains a half — exercises the FeatureScanner's
    /// struct-field walk (FLOAT16 should still trip from a VarDecl
    /// of HalfBundle even though the visible TypeExpr is `HalfBundle`).
    HalfBundle b;
    b.scale = 0.5h;
    b.tint  = make_half3(1.0, 1.0, 1.0);

    /// Final output stays float4 (the rasterizer doesn't read half).
    /// Cross-precision combination requires an explicit cast.
    float3 widened = make_float3(0.25, 0.5, 0.75);
    return float4(widened, 1.0);
}
