/// §3.6 — `++` and `--` are mutating operators; applying them to a
/// const local must be rejected the same way binary assignment is. The
/// check lives in the UNARY_EXPR branch of Sema, alongside the binary-
/// op assignment check.

struct Pt {
    float4 value;
};

buffer<Pt> dst : 0;

[out dst]
compute(x=1,y=1,z=1)
void test_invalid_const_increment(uint3 tid : GlobalThreadID){
    const int n = 1;
    /// Expected diagnostic: "Cannot modify `const` local `n`."
    ++n;
    dst[0].value = float4(float(n), 0.0, 0.0, 0.0);
}
