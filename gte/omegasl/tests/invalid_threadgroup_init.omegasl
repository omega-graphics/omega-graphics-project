
// §6.1 — thread-group-shared memory is uninitialized storage on every
// backend; an initializer is rejected at parse time.

struct Pixel {
    float4 color;
};

buffer<Pixel> pixels : 0;

[out pixels]
compute(x=8,y=8,z=1)
void bad_init(uint3 tid : GlobalThreadID){
    threadgroup float scratch = 1.0;
    pixels[tid[0]].color = float4(scratch, 0.0, 0.0, 1.0);
}
