// §5 negative — an amplification shader must declare exactly one `out payload`.
// A stage with no payload has nothing to hand the mesh threadgroups it
// dispatches, which means it exists only to multiply the dispatch count — and
// the host could have done that by passing a bigger grid to `drawMeshTasks`.

#requires(MESH_SHADERS)

struct MeshletVertex internal {
    float4 pos : Position;
};

amplification(x=1, y=1, z=1)
void ampFunc(uint3 gid : ThreadGroupID){
}

mesh(max_vertices=3, max_primitives=1, topology=triangle)
void meshFunc(uint3 gid : ThreadGroupID,
              out vertices MeshletVertex verts[3],
              out indices  uint3         tris[1]){
    verts[0].pos = float4(-0.5, -0.5, 0.0, 1.0);
    verts[1].pos = float4( 0.5, -0.5, 0.0, 1.0);
    verts[2].pos = float4( 0.0,  0.5, 0.0, 1.0);
    tris[0] = uint3(0, 1, 2);
}
