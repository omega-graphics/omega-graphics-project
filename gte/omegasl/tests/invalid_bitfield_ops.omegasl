// §5.3 — negative test for integer / bitfield ops. Multi-error:
//   (1) countbits on a float operand    — integer operands only.
//   (2) reversebits on a float operand  — integer operands only.
//   (3) countbits with the wrong arg count (takes exactly 1).
//   (4) firstbithigh on a float operand — integer operands only (Phase B).
//   (5) firstbitlow with the wrong arg count (Phase B).

struct Data { uint4 value; };

buffer<Data> input : 0;
buffer<Data> output : 1;

[in input, out output]
compute(x=1,y=1,z=1)
void test_bad(uint3 tid : GlobalThreadID){
    float f = 1.5;
    uint  a = input[0].value[0];

    uint bad1 = countbits(f);          // (1) float operand
    uint bad2 = reversebits(f);        // (2) float operand
    uint bad3 = countbits(a, a);       // (3) arg count
    int  bad4 = firstbithigh(f);       // (4) float operand
    int  bad5 = firstbitlow(a, a);     // (5) arg count
    uint bad6 = bitfieldExtract(f, 0, 4);       // (6) float operand
    uint bad7 = bitfieldInsert(a, a, 0);        // (7) arg count (wants 4)
    uint bad8 = bitfieldExtract(a, 0, f);       // (8) float bit-count arg

    output[0].value = uint4(bad1, bad2, bad3,
                            (uint)bad4 + (uint)bad5 + bad6 + bad7 + bad8);
}
