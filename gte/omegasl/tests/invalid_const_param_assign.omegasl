/// §3.6 — writing through a `const` parameter must be a hard error,
/// the same way writing a `const` local is. The param binding carries
/// the immutability flag into Sema's variable map, so the existing
/// binary-assign check fires on it. The harness only checks failure.

struct Pt {
    float4 value;
};

buffer<Pt> dst : 0;

/// Expected diagnostic: "Cannot assign to `const` local `v`."
/// (the const-binding check is shared between locals and params.)
float bump(const float v){
    v = v + 1.0;
    return v;
}

[out dst]
compute(x=1,y=1,z=1)
void test_invalid_const_param_assign(uint3 tid : GlobalThreadID){
    float r = bump(2.0);
    dst[0].value = float4(r, r, r, r);
}
