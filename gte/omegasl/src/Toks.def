#ifndef OMEGASL_TOKS_DEF
#define OMEGASL_TOKS_DEF

namespace omegasl {
    typedef int TokType;
}

#define TOK_MAX_LEN 200

#define TOK(content) content
#define KW(content) TOK(content)
#define KW_TY(content) TOK(content)
#define OP(content) TOK(content)

#define TOK_ID 0x01
#define TOK_ASTERISK 0x02
#define TOK_KW 0x03
#define TOK_OP 0x04
#define TOK_LBRACE 0x05
#define TOK_RBRACE 0x06
#define TOK_LPAREN 0x07
#define TOK_RPAREN 0x08
#define TOK_DOT 0x09
#define TOK_LBRACKET 0x0A
#define TOK_RBRACKET 0x0B
#define TOK_AMPERSAND 0x0C
#define TOK_COLON 0x0D
#define TOK_SEMICOLON 0x0E
#define TOK_KW_TYPE 0x0F

#define TOK_NUM_LITERAL 0x10
#define TOK_STR_LITERAL 0x11
#define TOK_COMMA 0x12
/// §3.2 — ternary operator's `?`. Stored as its own token type so the
/// parser can branch on it without overloading TOK_OP (which would
/// require the precedence-climbing loop to special-case ternary's
/// non-binary shape).
#define TOK_QUESTION 0x13

#define TOK_EOF 0xFF

#define OP_EQUAL OP("=")
#define OP_ISEQUAL OP("==")
#define OP_PLUS OP("+")
#define OP_PLUSPLUS OP("++")
#define OP_PLUSEQUAL OP("+=")
#define OP_MINUS OP("-")
#define OP_MINUSMINUS OP("--")
#define OP_MINUSEQUAL OP("-=")
#define OP_DIV OP("/")
#define OP_DIVEQUAL OP("/=")
#define OP_MULEQUAL OP("*=")
#define OP_MOD OP("%")
#define OP_MODEQUAL OP("%=")
#define OP_GREATER OP(">")
#define OP_GREATEREQUAL OP(">=")
#define OP_LESS OP("<")
#define OP_LESSEQUAL OP("<=")
#define OP_NOT OP("!")
#define OP_NOTEQUAL OP("!=")

#define OP_BITAND OP("&")
#define OP_BITOR OP("|")
#define OP_BITXOR OP("^")
#define OP_BITNOT OP("~")
#define OP_LSHIFT OP("<<")
#define OP_RSHIFT OP(">>")
#define OP_LOGAND OP("&&")
#define OP_LOGOR OP("||")
#define OP_ANDEQUAL OP("&=")
#define OP_OREQUAL OP("|=")
#define OP_XOREQUAL OP("^=")
#define OP_LSHIFTEQUAL OP("<<=")
#define OP_RSHIFTEQUAL OP(">>=")


#define KW_VERTEX KW("vertex")
#define KW_FRAGMENT KW("fragment")
#define KW_COMPUTE KW("compute")
#define KW_HULL KW("hull")
#define KW_DOMAIN KW("domain")
/// Mesh-shader pipeline mesh stage. Like the other stage keywords, this is
/// a hard keyword. The descriptor sub-words (`max_vertices`, `max_primitives`,
/// `topology`) and the output qualifiers (`vertices`, `indices`) stay
/// contextual identifiers — matched positionally by the parser the way the
/// tessellation descriptor matches `partitioning` / `outputtopology` — so
/// they remain legal identifiers everywhere else.
#define KW_MESH KW("mesh")
/// Mesh-shader pipeline amplification (a.k.a. task / object) stage — §5.
/// Hard keyword, like every other stage keyword. The payload qualifier
/// (`payload`) stays a contextual identifier, consumed by the parser only
/// when it directly follows an `in` / `out` access qualifier on a shader
/// parameter — the same trick `vertices` / `indices` use — so `payload`
/// remains a legal identifier everywhere else.
#define KW_AMPLIFICATION KW("amplification")
#define KW_IF KW("if")
#define KW_ELSE KW("else")
#define KW_FOR KW("for")
#define KW_WHILE KW("while")
#define KW_BREAK KW("break")
#define KW_CONTINUE KW("continue")
#define KW_DISCARD KW("discard")
#define KW_SWITCH KW("switch")
#define KW_CASE KW("case")
#define KW_DEFAULT KW("default")
#define KW_STRUCT KW("struct")
#define KW_INTERNAL KW("internal")
#define KW_RETURN KW("return")
#define KW_IN KW("in")
#define KW_OUT KW("out")
#define KW_INOUT KW("inout")
#define KW_STATIC KW("static")
/// §3.6 — `const` qualifier on local variable declarations. Marks the
/// local immutable from declaration on; assignment to it is rejected by
/// Sema and the qualifier flows through to all three backend targets,
/// each of which spell it `const` in their generated source.
#define KW_CONST KW("const")
/// §6.1 — `threadgroup` storage qualifier on a local variable declared at
/// the top level of a compute shader body. Declares thread-group-shared
/// memory. Per backend: `groupshared` (HLSL), `threadgroup` (MSL),
/// `shared` (GLSL). HLSL `groupshared` and GLSL `shared` are global-scope
/// only, so those backends hoist the declaration to file scope; MSL keeps
/// it inline at kernel scope. Shared memory is uninitialized — no
/// initializer is permitted.
#define KW_THREADGROUP KW("threadgroup")


#define KW_TY_VOID KW_TY("void")
#define KW_TY_BOOL KW_TY("bool")
/// §5.2 — bool vectors. Native on HLSL/MSL (`bool2/3/4`); GLSL spells
/// them `bvec2/3/4`. Universally supported, so no feature-bit gate.
/// Produced by the component-wise comparison builtins (lessThan, …) and
/// consumed by `any`/`all`.
#define KW_TY_BOOL2 KW_TY("bool2")
#define KW_TY_BOOL3 KW_TY("bool3")
#define KW_TY_BOOL4 KW_TY("bool4")
#define KW_TY_INT KW_TY("int")
#define KW_TY_INT2 KW_TY("int2")
#define KW_TY_INT3 KW_TY("int3")
#define KW_TY_INT4 KW_TY("int4")
/// §12.2 follow-up — integer matrix types. No backend has a native integer
/// matrix (GLSL `mat`/`dmat` and MSL `metal::matrix` are float/half only;
/// only HLSL has `int4x4`), so OmegaSL lowers `intCxR` uniformly to an array
/// of C integer column-vectors (`int4 m[C]` / `ivec4 m[C]`) on every backend.
#define KW_TY_INT2X2 KW_TY("int2x2")
#define KW_TY_INT3X3 KW_TY("int3x3")
#define KW_TY_INT4X4 KW_TY("int4x4")
#define KW_TY_INT2X3 KW_TY("int2x3")
#define KW_TY_INT2X4 KW_TY("int2x4")
#define KW_TY_INT3X2 KW_TY("int3x2")
#define KW_TY_INT3X4 KW_TY("int3x4")
#define KW_TY_INT4X2 KW_TY("int4x2")
#define KW_TY_INT4X3 KW_TY("int4x3")
#define KW_TY_FLOAT KW_TY("float")
#define KW_TY_FLOAT2 KW_TY("float2")
#define KW_TY_FLOAT3 KW_TY("float3")
#define KW_TY_FLOAT4 KW_TY("float4")
#define KW_TY_FLOAT2X2 KW_TY("float2x2")
#define KW_TY_FLOAT3X3 KW_TY("float3x3")
#define KW_TY_FLOAT4X4 KW_TY("float4x4")
#define KW_TY_FLOAT2X3 KW_TY("float2x3")
#define KW_TY_FLOAT2X4 KW_TY("float2x4")
#define KW_TY_FLOAT3X2 KW_TY("float3x2")
#define KW_TY_FLOAT3X4 KW_TY("float3x4")
#define KW_TY_FLOAT4X2 KW_TY("float4x2")
#define KW_TY_FLOAT4X3 KW_TY("float4x3")
#define KW_TY_DOUBLE KW_TY("double")
#define KW_TY_DOUBLE2 KW_TY("double2")
#define KW_TY_DOUBLE3 KW_TY("double3")
#define KW_TY_DOUBLE4 KW_TY("double4")
#define KW_TY_UINT KW_TY("uint")
#define KW_TY_UINT2 KW_TY("uint2")
#define KW_TY_UINT3 KW_TY("uint3")
#define KW_TY_UINT4 KW_TY("uint4")
/// §12.2 follow-up — unsigned-integer matrix types. Same uniform
/// array-of-column-vectors lowering as the signed `intCxR` family above.
#define KW_TY_UINT2X2 KW_TY("uint2x2")
#define KW_TY_UINT3X3 KW_TY("uint3x3")
#define KW_TY_UINT4X4 KW_TY("uint4x4")
#define KW_TY_UINT2X3 KW_TY("uint2x3")
#define KW_TY_UINT2X4 KW_TY("uint2x4")
#define KW_TY_UINT3X2 KW_TY("uint3x2")
#define KW_TY_UINT3X4 KW_TY("uint3x4")
#define KW_TY_UINT4X2 KW_TY("uint4x2")
#define KW_TY_UINT4X3 KW_TY("uint4x3")

/// §4.1 16-bit numeric types. Backed by OMEGASL_FEATURE_BIT_FLOAT16
/// (for `half`) — usage from a shader body trips the bit so the runtime
/// can decline on devices without 16-bit support. Mappings:
///   HLSL  → `float16_t` (SM 6.2 + `-enable-16bit-types`)
///   MSL   → `half` (native since Metal 1.0)
///   GLSL  → `float16_t` (`GL_EXT_shader_explicit_arithmetic_types_float16`)
#define KW_TY_HALF KW_TY("half")
#define KW_TY_HALF2 KW_TY("half2")
#define KW_TY_HALF3 KW_TY("half3")
#define KW_TY_HALF4 KW_TY("half4")

/// §4.1 16-bit signed/unsigned integers. The bit gating reuses
/// OMEGASL_FEATURE_BIT_FLOAT16 — every modern surface that ships
/// `float16_t` also ships `int16_t`/`uint16_t` (and the GLSL extension
/// is the same family).
#define KW_TY_SHORT KW_TY("short")
#define KW_TY_SHORT2 KW_TY("short2")
#define KW_TY_SHORT3 KW_TY("short3")
#define KW_TY_SHORT4 KW_TY("short4")
#define KW_TY_USHORT KW_TY("ushort")
#define KW_TY_USHORT2 KW_TY("ushort2")
#define KW_TY_USHORT3 KW_TY("ushort3")
#define KW_TY_USHORT4 KW_TY("ushort4")

/// §4.2 64-bit integer types. Gated by OMEGASL_FEATURE_BIT_INT64.
///   HLSL  → `int64_t`/`uint64_t` (SM 6.0)
///   MSL   → `long`/`ulong` (MSL 2.0+; iOS support varies — runtime gate
///            is the safety net)
///   GLSL  → `int64_t`/`uint64_t` (`GL_EXT_shader_explicit_arithmetic_types_int64`
///            or `GL_ARB_gpu_shader_int64`).
#define KW_TY_LONG KW_TY("long")
#define KW_TY_LONG2 KW_TY("long2")
#define KW_TY_LONG3 KW_TY("long3")
#define KW_TY_LONG4 KW_TY("long4")
#define KW_TY_ULONG KW_TY("ulong")
#define KW_TY_ULONG2 KW_TY("ulong2")
#define KW_TY_ULONG3 KW_TY("ulong3")
#define KW_TY_ULONG4 KW_TY("ulong4")

#define KW_TY_BUFFER KW_TY("buffer")
/// §2.4 constant / uniform buffer. Distinct from `buffer` (StructuredBuffer
/// / SSBO): smaller, std140-aligned, read-only, accessed as a value (no
/// indexing). Maps to ConstantBuffer<T> (HLSL) / `constant T&` (MSL) /
/// `layout(std140) uniform` (GLSL).
#define KW_TY_UNIFORM KW_TY("uniform")
/// §2.2 (Pipeline-Completion) / §10.2 push constants. A third resource form
/// after `buffer`/`uniform`: small (≤128 bytes portable), read-only,
/// value-accessed (no indexing), declared globally with an index and opted
/// into per-shader via the resource map — same scoping as every other
/// resource (entry-scoped, not an ambient global; threaded into helpers as a
/// param, which is what Metal requires). Distinct from `uniform` only in how
/// it is *bound* at runtime (root constants on D3D12, `setBytes` on Metal,
/// `vkCmdPushConstants` on Vulkan) — there is no descriptor/buffer
/// allocation. Maps to ConstantBuffer<T> at a `b` register (HLSL),
/// `constant T&` (MSL, same as uniform), `layout(push_constant) uniform`
/// block (GLSL).
#define KW_TY_CONSTANT KW_TY("constant")
#define KW_TY_TEXTURE1D KW_TY("texture1d")
#define KW_TY_TEXTURE2D KW_TY("texture2d")
#define KW_TY_TEXTURE3D KW_TY("texture3d")
#define KW_TY_TEXTURE1D_ARRAY KW_TY("texture1d_array")
#define KW_TY_TEXTURE2D_ARRAY KW_TY("texture2d_array")
#define KW_TY_TEXTURECUBE KW_TY("texturecube")
#define KW_TY_TEXTURECUBE_ARRAY KW_TY("texturecube_array")
#define KW_TY_TEXTURE2D_MS KW_TY("texture2d_ms")
#define KW_TY_TEXTURE2D_MS_ARRAY KW_TY("texture2d_ms_array")
#define KW_TY_SAMPLER1D KW_TY("sampler1d")
#define KW_TY_SAMPLER2D KW_TY("sampler2d")
#define KW_TY_SAMPLER3D KW_TY("sampler3d")
#define KW_TY_SAMPLERCUBE KW_TY("samplercube")

/// §5.6 — atomic scalar types. `atomic_int` / `atomic_uint` carry the
/// atomicity in the *type* (MSL's requirement); they spell as `atomic_int` /
/// `atomic_uint` on MSL but as plain `int` / `uint` on HLSL / GLSL, and are
/// only ever touched through the `atomic_*` intrinsics + `atomic_load` /
/// `atomic_store`.
#define KW_TY_ATOMIC_INT KW_TY("atomic_int")
#define KW_TY_ATOMIC_UINT KW_TY("atomic_uint")

/// Inline ray tracing (Raytracing plan §1.2). `Ray` and `RayHit` are
/// builtin *struct* types (they carry named fields the shader reads /
/// writes — `ray.origin`, `hit.t`), so unlike every other builtin they
/// resolve with `builtin=false` and populated `fields` and are emitted as
/// real `struct` definitions in each backend. `AccelerationStructure` is an
/// opaque, resource-bound handle (like a texture): declared `... : N`,
/// listed in a compute shader's resource map, and passed to `intersect()`.
/// Per backend: HLSL `RaytracingAccelerationStructure` (SM 6.5 RayQuery),
/// GLSL `accelerationStructureEXT` (GL_EXT_ray_query), MSL
/// `acceleration_structure<instancing>` (<metal_raytracing>). The low-level
/// `RayQuery` (sub-phase 1.5) is the opaque low-level ray-query object for the
/// explicit traversal loop (non-opaque / alpha-tested triangles). Like
/// `AccelerationStructure` it is `builtin = true` with no user-visible fields —
/// declared as a local (`RayQuery q;`) and mutated in place by the
/// `ray_query_*` intrinsics. Per backend: HLSL `RayQuery<RAY_FLAG_NONE>`, GLSL
/// `rayQueryEXT`, Metal `intersection_query<triangle_data, instancing>`.
#define KW_TY_RAY KW_TY("Ray")
#define KW_TY_RAY_HIT KW_TY("RayHit")
#define KW_TY_ACCELERATION_STRUCTURE KW_TY("AccelerationStructure")
#define KW_TY_RAY_QUERY KW_TY("RayQuery")


#endif // OMEGASL_TOKS_DEF
