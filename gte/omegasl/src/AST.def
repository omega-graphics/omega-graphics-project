#define ATTRIBUTE_VERTEX_ID "VertexID"
#define ATTRIBUTE_INSTANCE_ID "InstanceID"
#define ATTRIBUTE_POSITION "Position"
#define ATTRIBUTE_COLOR "Color"
#define ATTRIBUTE_TEXCOORD "TexCoord"
#define ATTRIBUTE_GLOBALTHREAD_ID "GlobalThreadID"
#define ATTRIBUTE_THREADGROUP_ID "ThreadGroupID"
#define ATTRIBUTE_LOCALTHREAD_ID "LocalThreadID"
#define ATTRIBUTE_DEPTH "Depth"
#define ATTRIBUTE_FRONTFACING "FrontFacing"
#define ATTRIBUTE_SAMPLEINDEX "SampleIndex"
#define ATTRIBUTE_INPUT_COVERAGE "InputCoverage"
#define ATTRIBUTE_OUTPUT_COVERAGE "OutputCoverage"
/// §1.7 — user clip / cull distances on a vertex/hull/domain output struct.
/// Float scalar or float array field. ClipDistance → SV_ClipDistance /
/// gl_ClipDistance[] / [[clip_distance]] (all backends). CullDistance →
/// SV_CullDistance / gl_CullDistance[] (HLSL/GLSL); Metal has no cull-distance
/// equivalent, so CullDistance is gated by OMEGASL_FEATURE_BIT_CULL_DISTANCE
/// and stubs on MSL.
#define ATTRIBUTE_CLIP_DISTANCE "ClipDistance"
#define ATTRIBUTE_CULL_DISTANCE "CullDistance"

// Static Sampler Properties
#define SAMPLER_PROP_FILTER "filter"
#define SAMPLER_PROP_MIN_FILTER "min_filter"
#define SAMPLER_PROP_MAG_FILTER "mag_filter"
#define SAMPLER_PROP_MIP_FILTER "mip_filter"

#define SAMPLER_FILTER_ANISOTROPIC "anisotropic"
