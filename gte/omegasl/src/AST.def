#ifndef OMEGASL_AST_DEF
#define OMEGASL_AST_DEF

typedef int ASTType;

#define DECL 0x000F
#define EXPR 0x000A

#define FUNC_DECL (0x0010 | DECL)
#define SHADER_DECL (0x0020 | DECL)
#define RESOURCE_DECL (0x0030 | DECL)
#define VAR_DECL (0x0040 | DECL)
#define IF_DECL (0x0050 | DECL)
#define ELSE_DECL (0x0060 | DECL)
#define ELSEIF_DECL (0x0070 | DECL)
#define STRUCT_DECL (0x0080 | DECL)
#define RETURN_DECL (0x0090 | DECL)
#define IF_STMT (0x00A0 | DECL)
#define FOR_STMT (0x00B0 | DECL)
#define WHILE_STMT (0x00C0 | DECL)
#define BREAK_STMT (0x00D0 | DECL)
#define CONTINUE_STMT (0x00E0 | DECL)
#define DISCARD_STMT (0x00F0 | DECL)
#define SWITCH_STMT (0x0100 | DECL)

#define ID_EXPR (0x0010 | EXPR)
#define LITERAL_EXPR (0x0020 | EXPR)
#define ARRAY_EXPR (0x0030 | EXPR)
#define CALL_EXPR (0x0040 | EXPR)
#define MEMBER_EXPR (0x0050 | EXPR)
#define BINARY_EXPR (0x0060 | EXPR)
#define POINTER_EXPR (0x0070 | EXPR)
#define UNARY_EXPR (0x0080 | EXPR)
#define INDEX_EXPR (0x0090 | EXPR)
#define CAST_EXPR (0x00A0 | EXPR)
/// §3.2 — ternary `cond ? a : b`. Its three child expressions live on
/// `TernaryExpr`; the resolved type is the common type of `a` and `b`.
#define TERNARY_EXPR (0x00B0 | EXPR)


/// Builtins Functions
#define BUILTIN_MAKE_FLOAT2 "make_float2"
#define BUILTIN_MAKE_FLOAT3 "make_float3"
#define BUILTIN_MAKE_FLOAT4 "make_float4"

#define BUILTIN_DOT "dot"
#define BUILTIN_CROSS "cross"
#define BUILTIN_SAMPLE "sample"
#define BUILTIN_SAMPLE_LOD "sampleLOD"
#define BUILTIN_SAMPLE_BIAS "sampleBias"
#define BUILTIN_SAMPLE_GRAD "sampleGrad"
#define BUILTIN_GATHER "gather"
#define BUILTIN_GATHER_RED "gatherRed"
#define BUILTIN_GATHER_GREEN "gatherGreen"
#define BUILTIN_GATHER_BLUE "gatherBlue"
#define BUILTIN_GATHER_ALPHA "gatherAlpha"
#define BUILTIN_WRITE "write"
#define BUILTIN_READ "read"

#define BUILTIN_MAKE_INT2 "make_int2"
#define BUILTIN_MAKE_INT3 "make_int3"
#define BUILTIN_MAKE_INT4 "make_int4"
#define BUILTIN_MAKE_UINT2 "make_uint2"
#define BUILTIN_MAKE_UINT3 "make_uint3"
#define BUILTIN_MAKE_UINT4 "make_uint4"
/// §4.1 16-bit vector constructors. The make_* prefix matches the
/// existing convention; sema and codegen reuse the same dispatch.
#define BUILTIN_MAKE_HALF2 "make_half2"
#define BUILTIN_MAKE_HALF3 "make_half3"
#define BUILTIN_MAKE_HALF4 "make_half4"
#define BUILTIN_MAKE_SHORT2 "make_short2"
#define BUILTIN_MAKE_SHORT3 "make_short3"
#define BUILTIN_MAKE_SHORT4 "make_short4"
#define BUILTIN_MAKE_USHORT2 "make_ushort2"
#define BUILTIN_MAKE_USHORT3 "make_ushort3"
#define BUILTIN_MAKE_USHORT4 "make_ushort4"
/// §4.2 64-bit vector constructors.
#define BUILTIN_MAKE_LONG2 "make_long2"
#define BUILTIN_MAKE_LONG3 "make_long3"
#define BUILTIN_MAKE_LONG4 "make_long4"
#define BUILTIN_MAKE_ULONG2 "make_ulong2"
#define BUILTIN_MAKE_ULONG3 "make_ulong3"
#define BUILTIN_MAKE_ULONG4 "make_ulong4"

#define BUILTIN_MAKE_FLOAT2X2 "make_float2x2"
#define BUILTIN_MAKE_FLOAT3X3 "make_float3x3"
#define BUILTIN_MAKE_FLOAT4X4 "make_float4x4"
#define BUILTIN_MAKE_FLOAT2X3 "make_float2x3"
#define BUILTIN_MAKE_FLOAT2X4 "make_float2x4"
#define BUILTIN_MAKE_FLOAT3X2 "make_float3x2"
#define BUILTIN_MAKE_FLOAT3X4 "make_float3x4"
#define BUILTIN_MAKE_FLOAT4X2 "make_float4x2"
#define BUILTIN_MAKE_FLOAT4X3 "make_float4x3"

/// Math Intrinsics
/// 1-arg: same type in, same type out
#define BUILTIN_SIN "sin"
#define BUILTIN_COS "cos"
#define BUILTIN_TAN "tan"
#define BUILTIN_ASIN "asin"
#define BUILTIN_ACOS "acos"
#define BUILTIN_ATAN "atan"
#define BUILTIN_SQRT "sqrt"
#define BUILTIN_ABS "abs"
#define BUILTIN_FLOOR "floor"
#define BUILTIN_CEIL "ceil"
#define BUILTIN_ROUND "round"
#define BUILTIN_FRAC "frac"
#define BUILTIN_NORMALIZE "normalize"
#define BUILTIN_LENGTH "length"
#define BUILTIN_EXP "exp"
#define BUILTIN_EXP2 "exp2"
#define BUILTIN_LOG "log"
#define BUILTIN_LOG2 "log2"
/// 1-arg: §5.1 Phase A — sign-preserving / saturation / hyperbolic math
#define BUILTIN_SIGN "sign"
#define BUILTIN_SATURATE "saturate"
#define BUILTIN_TRUNC "trunc"
#define BUILTIN_RSQRT "rsqrt"
#define BUILTIN_DEGREES "degrees"
#define BUILTIN_RADIANS "radians"
#define BUILTIN_SINH "sinh"
#define BUILTIN_COSH "cosh"
#define BUILTIN_TANH "tanh"
/// 2-arg: same type in, same type out
#define BUILTIN_ATAN2 "atan2"
#define BUILTIN_POW "pow"
#define BUILTIN_MIN "min"
#define BUILTIN_MAX "max"
#define BUILTIN_STEP "step"
#define BUILTIN_REFLECT "reflect"
/// 2-arg: §5.1 — truncation-style modulus (matches C/HLSL/MSL `fmod`,
/// not GLSL's `mod`) and binary-exponent scale.
#define BUILTIN_FMOD "fmod"
#define BUILTIN_LDEXP "ldexp"
/// 3-arg: same type in, same type out
#define BUILTIN_CLAMP "clamp"
#define BUILTIN_LERP "lerp"
#define BUILTIN_SMOOTHSTEP "smoothstep"
/// 3-arg: §5.1 — fused multiply-add. HLSL backend lowers to `mad`
/// (broadly available; precision contract looser than IEEE 754 fma).
#define BUILTIN_FMA "fma"

