/// Math Intrinsics
/// 1-arg: same type in, same type out
#define BUILTIN_SIN "sin"
#define BUILTIN_COS "cos"
#define BUILTIN_TAN "tan"
#define BUILTIN_ASIN "asin"
#define BUILTIN_ACOS "acos"
#define BUILTIN_ATAN "atan"
#define BUILTIN_SQRT "sqrt"
#define BUILTIN_ABS "abs"
#define BUILTIN_FLOOR "floor"
#define BUILTIN_CEIL "ceil"
#define BUILTIN_ROUND "round"
#define BUILTIN_FRAC "frac"
#define BUILTIN_NORMALIZE "normalize"
#define BUILTIN_LENGTH "length"
#define BUILTIN_EXP "exp"
#define BUILTIN_EXP2 "exp2"
#define BUILTIN_LOG "log"
#define BUILTIN_LOG2 "log2"
/// 1-arg: б§5.1 Phase A Бқ” sign-preserving / saturation / hyperbolic math
#define BUILTIN_SIGN "sign"
#define BUILTIN_SATURATE "saturate"
#define BUILTIN_TRUNC "trunc"
#define BUILTIN_RSQRT "rsqrt"
#define BUILTIN_DEGREES "degrees"
#define BUILTIN_RADIANS "radians"
#define BUILTIN_SINH "sinh"
#define BUILTIN_COSH "cosh"
#define BUILTIN_TANH "tanh"
/// 2-arg: same type in, same type out
#define BUILTIN_ATAN2 "atan2"
#define BUILTIN_POW "pow"
#define BUILTIN_MIN "min"
#define BUILTIN_MAX "max"
#define BUILTIN_STEP "step"
#define BUILTIN_REFLECT "reflect"
/// 2-arg: б§5.1 Бқ” truncation-style modulus (matches C/HLSL/MSL `fmod`,
/// not GLSL's `mod`) and binary-exponent scale.
#define BUILTIN_FMOD "fmod"
#define BUILTIN_LDEXP "ldexp"
/// 3-arg: same type in, same type out
#define BUILTIN_CLAMP "clamp"
#define BUILTIN_LERP "lerp"
#define BUILTIN_SMOOTHSTEP "smoothstep"
/// 3-arg: б§5.1 Бқ” fused multiply-add. HLSL backend lowers to `mad`
/// (broadly available; precision contract looser than IEEE 754 fma).
#define BUILTIN_FMA "fma"

/// б§5.2 Бқ” vector / matrix math.
///   distance(a,b)        Бқ” 2-arg, returns a scalar `float` (length of a-b).
///   faceforward(n,i,ng)  Бқ” 3-arg, returns same type as `n` (flip toward viewer).
///   refract(i,n,eta)     Бқ” 3-arg (i,n vectors, eta scalar), returns `i`'s type.
/// All three are native on HLSL/MSL/GLSL and pass through unchanged.
///   inverse(m)           Бқ” 1-arg, square matrix in, same type out. GLSL has a
/// native `inverse`; HLSL and MSL do NOT (verified Бқ” `metal::inverse` is
/// undeclared), so both lower the call to an injected scalar adjugate
/// expansion (see CodeGen::tryEmitInverse).
#define BUILTIN_DISTANCE "distance"
#define BUILTIN_FACEFORWARD "faceforward"
#define BUILTIN_REFRACT "refract"
#define BUILTIN_INVERSE "inverse"

/// б§5.2 Бқ” boolean reduction + component-wise comparison.
///   any(v) / all(v)  Бқ” 1-arg, reduce a bool vector (bool2/3/4) to a
///     scalar `bool`. Native + identically spelled on all three backends
///     (HLSL/MSL/GLSL `any`/`all`), so they pass through `renameBuiltin`.
///   lessThan / lessThanEqual / greaterThan / greaterThanEqual / equal /
///     notEqual Бқ” 2-arg, component-wise compare of two same-type numeric
///     vectors (floatN/intN/uintN/Бқ¦) producing the matching bool vector.
///     GLSL has these as native functions; HLSL and MSL have no such
///     function Бқ” they spell component-wise compare with the operators
///     (`a < b` on vectors yields a bool vector on both), so those two
///     backends rewrite the call to `(a OP b)` in `tryEmitBuiltinCall`.
///     The OmegaSL surface stays GLSL-shaped because б§3.2 deliberately
///     made the scalar relational operators yield a *scalar* bool Бқ” a
///     named builtin is how component-wise compare stays unambiguous.
#define BUILTIN_ANY "any"
#define BUILTIN_ALL "all"
#define BUILTIN_LESSTHAN "lessThan"
#define BUILTIN_LESSTHANEQUAL "lessThanEqual"
#define BUILTIN_GREATERTHAN "greaterThan"
#define BUILTIN_GREATERTHANEQUAL "greaterThanEqual"
#define BUILTIN_EQUAL "equal"
#define BUILTIN_NOTEQUAL "notEqual"

/// б§5.3 Бқ” integer / bitfield ops. Phase A: `countbits` / `reversebits`
/// are 1-arg, same-type-out (population count / bit-reverse), restricted
/// to integer scalar/vector operands (int/uint/intN/uintN). Per backend:
///   countbits   Б†’ popcount (MSL, native TБ†’T) / bitCount (GLSL, returns a
///     *signed* iN Бқ” cast back to the operand type) / countbits (HLSL,
///     scalar-uint only Бқ” vectors expand component-wise, signed casts back).
///   reversebits Б†’ reverse_bits (MSL) / bitfieldReverse (GLSL, TБ†’T native) /
///     reversebits (HLSL, scalar-uint only Бқ” same vector expansion).
#define BUILTIN_COUNTBITS "countbits"
#define BUILTIN_REVERSEBITS "reversebits"

/// б§5.3 Бқ” Phase B: `firstbithigh` / `firstbitlow` find the highest / lowest
/// set bit of an integer scalar/vector operand. Fully normalized across
/// backends: the operand is treated as its raw *unsigned* bit pattern, and
/// the result is a signed `int` / `intN` giving the zero-based bit index,
/// or `-1` when no bit is set (operand is 0). GLSL `findMSB`/`findLSB` is
/// the reference (it already returns int/`-1`); the other two are converted
/// to match (host-verified identical for every input incl. 0 / sign bit):
///   firstbithigh Б†’ findMSB(uint)              (GLSL, native)
///                Б†’ (intN)firstbithigh(uint)    (HLSL, 0xFFFFFFFF-on-0 Б†’ -1)
///                Б†’ 31 - intN(clz(uint))        (MSL, clz(0)=32 Б†’ -1)
///   firstbitlow  Б†’ findLSB(uint)              (GLSL, native)
///                Б†’ (intN)firstbitlow(uint)     (HLSL, 0xFFFFFFFF-on-0 Б†’ -1)
///                Б†’ select(intN(ctz(uint)), -1, x==0)  (MSL)
/// The result is always signed int/intN regardless of operand signedness.
#define BUILTIN_FIRSTBITHIGH "firstbithigh"
#define BUILTIN_FIRSTBITLOW "firstbitlow"

/// б§5.3 Бқ” Phase C: bit-field extract / insert.
///   bitfieldExtract(value, offset, bits)        Бқ” 3-arg. Extracts `bits`
///     bits starting at `offset` from `value`. Unsigned `value` zero-extends;
///     signed `value` sign-extends from the top extracted bit. Returns
///     `value`'s type. `offset` / `bits` are scalar int/uint.
///   bitfieldInsert(base, insert, offset, bits)  Бқ” 4-arg. Replaces the
///     `bits`-wide field at `offset` in `base` with the low `bits` of
///     `insert`. Returns `base`'s type.
/// `value`/`base`/`insert` are integer scalar or vector (intN/uintN); the
/// vector forms apply the same scalar offset/bits to every component.
/// Per backend (host-verified bit-identical across 210 combos incl. bits==0):
///   GLSL Бқ” native `bitfieldExtract`/`bitfieldInsert` (offset/bits cast to int).
///   MSL  Бқ” native `extract_bits`/`insert_bits` (offset/bits cast to uint).
///   HLSL Бқ” NO named intrinsic; lowered to manual shift+mask (unsigned:
///          `(v>>off)&mask`; signed: arithmetic-shift sign-extend; insert:
///          `(base & ~(mask<<off)) | ((insert & mask)<<off)`).
#define BUILTIN_BITFIELD_EXTRACT "bitfieldExtract"
#define BUILTIN_BITFIELD_INSERT "bitfieldInsert"

/// б§5.4 Бқ” fragment-stage screen-space derivatives. All nine are 1-arg,
/// same-float-type-in / same-type-out (float / float2 / float3 / float4),
/// and only valid inside a fragment shader. Per backend:
///   ddx          Б†’ ddx (HLSL) / dfdx (MSL) / dFdx (GLSL)
///   ddy          Б†’ ddy / dfdy / dFdy
///   fwidth       Б†’ fwidth (every backend)
///   ddx_coarse   Б†’ ddx_coarse (HLSL native SM5+) / dfdx (MSL has no
///                  coarse variant Бқ” silently widens) / dFdxCoarse (GLSL
///                  core 4.50 / GL_ARB_derivative_control)
///   ddx_fine     Б†’ ddx_fine / dfdx (widen) / dFdxFine
///   ddy_coarse   Б†’ ddy_coarse / dfdy (widen) / dFdyCoarse
///   ddy_fine     Б†’ ddy_fine / dfdy (widen) / dFdyFine
///   fwidth_coarse Б†’ abs(ddx_coarse(t)) + abs(ddy_coarse(t)) (HLSL has
///                   no fwidth_coarse intrinsic Бқ” lowered inline via
///                   statement-injection capture, see HLSLTarget) /
///                   fwidth (MSL widens) / fwidthCoarse (GLSL)
///   fwidth_fine  Б†’ abs(ddx_fine(t)) + abs(ddy_fine(t)) / fwidth /
///                  fwidthFine
/// No feature bit: derivatives are universal in fragment stage on every
/// backend, and the HLSL fwidth_coarse/fine lowering keeps coverage
/// uniform without a #requires gate.
#define BUILTIN_DDX "ddx"
#define BUILTIN_DDY "ddy"
#define BUILTIN_FWIDTH "fwidth"
#define BUILTIN_DDX_COARSE "ddx_coarse"
#define BUILTIN_DDX_FINE "ddx_fine"
#define BUILTIN_DDY_COARSE "ddy_coarse"
#define BUILTIN_DDY_FINE "ddy_fine"
#define BUILTIN_FWIDTH_COARSE "fwidth_coarse"
#define BUILTIN_FWIDTH_FINE "fwidth_fine"

/// б§5.5 Phase A Бқ” bit-pattern reinterpret. All three are 1-arg, accept a
/// 32-bit numeric scalar/vector operand (float / int / uint, scalar or
/// vector form), and return a same-arity scalar/vector of the fixed
/// target type. 16-bit and 64-bit operands are rejected Бқ” only 32-bit
/// reinterpret is uniform across backends (HLSL `asint(half)` doesn't
/// exist; MSL `as_type<uint>(half)` would change width). Same-signedness
/// passes through as an identity / constructor cast.
///   asint   Б†’ int / intN
///   asuint  Б†’ uint / uintN
///   asfloat Б†’ float / floatN
/// Per backend:
///   HLSL Бқ” native `asint` / `asuint` / `asfloat` (passes through
///          `tryEmitBuiltinCall` Бқ” pinned there rather than as a plain
///          rename because the same name shape lands consistently with
///          the GLSL / MSL handlers below).
///   MSL  Бқ” `as_type<targetN>(operand)` (single template Бқ” same name
///          regardless of operand signedness / float-ness).
///   GLSL Бқ” name varies by operand type:
///            floatБ†’int  `floatBitsToInt(x)`
///            floatБ†’uint `floatBitsToUint(x)`
///            int  Б†’float`intBitsToFloat(x)`
///            uint Б†’float`uintBitsToFloat(x)`
///            int  Б†’uint `uvecN(x)` (constructor Бқ” GLSL preserves bits)
///            uint Б†’int  `ivecN(x)` (constructor Бқ” GLSL preserves bits)
///            same-target identity emits the operand bare.
#define BUILTIN_ASINT "asint"
#define BUILTIN_ASUINT "asuint"
#define BUILTIN_ASFLOAT "asfloat"

/// б§5.5 Phase B Бқ” half-float pack / unpack. Two shapes:
///
///   Scalar (HLSL-named):
///     f16tof32(uint x)  Б†’ float    Бқ” interpret the low 16 bits of `x`
///                                    as an IEEE-754 binary16 and promote
///                                    to float. The high 16 bits are
///                                    ignored.
///     f32tof16(float x) Б†’ uint     Бқ” convert `x` to binary16 and store
///                                    the 16-bit pattern in the low 16
///                                    bits of the result; the high 16
///                                    bits are zero.
///
///   Packed (GLSL-named):
///     packHalf2x16(float2 v) Б†’ uint
///                              Бқ” convert v.x to binary16 into the low 16
///                                bits and v.y into the high 16 bits.
///     unpackHalf2x16(uint u) Б†’ float2
///                              Бқ” inverse of packHalf2x16.
///
/// Per backend:
///   HLSL Бқ” f16tof32 / f32tof16 are native (scalar + vector overloads, SM
///          5.0+); pass through `renameBuiltin`. packHalf2x16 /
///          unpackHalf2x16 have no native form and are lowered inline via
///          statement injection (single-eval temp + the scalar formula:
///          pack `(f32tof16(t.x) | (f32tof16(t.y) << 16))`, unpack
///          `float2(f16tof32(t & 0xFFFFu), f16tof32(t >> 16))`).
///   MSL  Бқ” no native packed form; all four lower to `as_type` of the
///          matching half-typed value (single template, no statement
///          injection needed):
///          f16tof32(x)        Б†’ float(as_type<half>(ushort(x)))
///          f32tof16(x)        Б†’ uint(as_type<ushort>(half(x)))
///          packHalf2x16(v)    Б†’ as_type<uint>(half2(v))
///          unpackHalf2x16(u)  Б†’ float2(as_type<half2>(u))
///   GLSL Бқ” packHalf2x16 / unpackHalf2x16 are native; pass through. The
///          scalar pair lowers inline using the packed pair:
///          f16tof32(x)  Б†’ unpackHalf2x16(x).x
///          f32tof16(x)  Б†’ packHalf2x16(vec2(x, 0.0))
#define BUILTIN_F16TOF32 "f16tof32"
#define BUILTIN_F32TOF16 "f32tof16"
#define BUILTIN_PACK_HALF_2X16 "packHalf2x16"
#define BUILTIN_UNPACK_HALF_2X16 "unpackHalf2x16"

/// б§5.5 Phase C Бқ” normalized (snorm / unorm) 4x8 and 2x16 pack / unpack.
/// Eight 1-arg builtins. The "snorm" forms map components in [-1, 1] to
/// signed fixed-point bytes/shorts; the "unorm" forms map components in
/// [0, 1] to unsigned fixed-point bytes/shorts. All eight return a uint
/// (pack) or a `float4`/`float2` (unpack). Per the GLSL 4.5 spec:
///
///   packSnorm4x8(v)   Б†’ round(clamp(v_i, -1, +1) * 127), packed as 4 int8s
///   packUnorm4x8(v)   Б†’ round(clamp(v_i,  0,  1) * 255), packed as 4 uint8s
///   packSnorm2x16(v)  Б†’ round(clamp(v_i, -1, +1) * 32767), packed as 2 int16s
///   packUnorm2x16(v)  Б†’ round(clamp(v_i,  0,  1) * 65535), packed as 2 uint16s
///   unpack* Бқ” interpret the uint as the matching Nц—K layout and produce
///             `clamp(f / max, -1, 1)` (snorm) or `f / max` (unorm).
///
/// Per backend:
///   GLSL Бқ” all eight native (`packSnorm4x8` etc.); pass through.
///   MSL  Бқ” all eight native, but with the `pack_float_to_*` /
///          `unpack_*_to_float` spelling; per-name `renameBuiltin`
///          rewrites.
///   HLSL Бқ” NO named intrinsic. Lowered via shared `CodeGen::emitHLSL
///          PackNormalized` / `emitHLSLUnpackNormalized` helpers using
///          statement injection (single-eval temp Б†’ clamp Б†’ multiply by
///          the scale Б†’ round Б†’ mask Б†’ OR-shift assemble). The HLSL
///          lowerings are host-verified bit-identical to the GLSL/MSL
///          spec (same discipline as б§5.3 Phase C's manual bitfield
///          extract/insert), proven on the `omegagte_pack_ops` runtime
///          test via on-GPU `==` comparison against host-computed
///          reference bytes.
#define BUILTIN_PACK_SNORM_4X8 "packSnorm4x8"
#define BUILTIN_UNPACK_SNORM_4X8 "unpackSnorm4x8"
#define BUILTIN_PACK_UNORM_4X8 "packUnorm4x8"
#define BUILTIN_UNPACK_UNORM_4X8 "unpackUnorm4x8"
#define BUILTIN_PACK_SNORM_2X16 "packSnorm2x16"
#define BUILTIN_UNPACK_SNORM_2X16 "unpackSnorm2x16"
#define BUILTIN_PACK_UNORM_2X16 "packUnorm2x16"
#define BUILTIN_UNPACK_UNORM_2X16 "unpackUnorm2x16"

/// б§5.6 Бқ” atomic operations on `atomic_int` / `atomic_uint` memory (a
/// `buffer<T>` field or a `threadgroup atomic_uint`). Phase A: seven 2-arg
/// fetch-ops that return the *original* value, plus `atomic_load` (1-arg) /
/// `atomic_store` (2-arg, void). arg0 (`mem`) resolves to an atomic type and
/// must be a writable lvalue; the operand `v` matches the underlying scalar
/// (`atomic_int`Б†’int / `atomic_uint`Б†’uint) or is an integer literal. No
/// feature bit (32-bit int atomics are universal). Per backend (MSL memory
/// order is always `memory_order_relaxed`):
///   add/min/max/and/or/xor Б†’ InterlockedAdd/Min/Max/And/Or/Xor(dest,v,out
///     orig) (HLSL, statement-injected out temp) / atomic_fetch_*_explicit
///     (MSL) / atomicAdd/Min/Max/And/Or/Xor (GLSL).
///   exchange Б†’ InterlockedExchange (HLSL) / atomic_exchange_explicit (MSL) /
///     atomicExchange (GLSL).
///   load  Б†’ plain read `mem` (HLSL/GLSL Бқ” 32-bit aligned reads are atomic) /
///     atomic_load_explicit(&mem) (MSL).
///   store Б†’ plain write `(mem = v)` (HLSL/GLSL) /
///     atomic_store_explicit(&mem,v) (MSL).
#define BUILTIN_ATOMIC_ADD "atomic_add"
#define BUILTIN_ATOMIC_MIN "atomic_min"
#define BUILTIN_ATOMIC_MAX "atomic_max"
#define BUILTIN_ATOMIC_AND "atomic_and"
#define BUILTIN_ATOMIC_OR "atomic_or"
#define BUILTIN_ATOMIC_XOR "atomic_xor"
#define BUILTIN_ATOMIC_EXCHANGE "atomic_exchange"
#define BUILTIN_ATOMIC_LOAD "atomic_load"
#define BUILTIN_ATOMIC_STORE "atomic_store"

/// б§5.6 Phase B Бқ” `atomic_compare_exchange(mem, compare, desired)` Бқ” 3-arg.
/// Strong CAS: if the current value equals `compare`, store `desired`. Returns
/// the *original* value either way (the caller checks `result == compare` for
/// success). The contract is STRONG (no spurious failure) on every backend, to
/// match HLSL/GLSL Бқ” the only portable choice, since a strong CAS cannot be
/// made to fail spuriously. Per backend:
///   GLSL Бқ” `atomicCompSwap(mem, compare, desired)` (native strong, returns
///     original).
///   HLSL Бқ” `InterlockedCompareExchange(dest, compare, desired, out orig)`
///     (native strong); the original goes to an out-param, so statement-
///     injected like the fetch-ops, expression value = the temp.
///   MSL  Бқ” has only `atomic_compare_exchange_weak_explicit` (no strong form),
///     so strong is emulated with the canonical weak-in-a-loop: seed
///     `_exp = compare`, loop while the CAS fails AND `_exp == compare` (a
///     spurious failure leaves `_exp` unchanged; a genuine mismatch loads the
///     differing value into `_exp` and exits). `_exp` ends holding the original
///     value. Statement-injected (decl + while-loop), expression value = `_exp`.
#define BUILTIN_ATOMIC_COMPARE_EXCHANGE "atomic_compare_exchange"

/// б§5.6 Phase B Бқ” `atomic_compare_exchange_weak(mem, inout expected, desired)`
/// Бқ” 3-arg, returns `bool`. The *weak* CAS: it may fail spuriously even when
/// the value matched, so it is only correct inside a caller retry loop. This is
/// the loop-free primitive Бқ” `atomic_compare_exchange` (strong) is the
/// emulated-via-loop convenience. Shape matches Metal's native weak / C++
/// `std::atomic`: returns whether the store happened, and on failure writes the
/// current value back through `expected` (which must be a writable lvalue of
/// the underlying scalar Бқ” NOT a literal). `desired` is the underlying scalar
/// or an integer literal. Per backend:
///   MSL  Бқ” `atomic_compare_exchange_weak_explicit(&mem, &expected, desired,
///     relaxed, relaxed)` (native, inline Бқ” bool + in-place `expected` update).
///   HLSL Бқ” no weak form; emulated from strong `InterlockedCompareExchange`
///     (statement-injected): capture orig, `_ok = (orig == expected)`, write
///     `expected = orig`, value = `_ok`. Strong-satisfies-weak (never spurious).
///   GLSL Бқ” same emulation from `atomicCompSwap` (statement-injected).
#define BUILTIN_ATOMIC_COMPARE_EXCHANGE_WEAK "atomic_compare_exchange_weak"

/// б§5.1.0 Бқ” `mod` / `mad` are accepted as aliases of the canonical
/// `fmod` / `fma` spellings (see `ast::canonicalBuiltinAlias`). They
/// carry no separate semantics: `mod` is truncation-modulus like `fmod`
/// (not GLSL's floor-based `mod`), and `mad` is `fma`'s multiply-add.
#define BUILTIN_MOD "mod"
#define BUILTIN_MAD "mad"

/// б§5.1.0 Бқ” `modf(x, out ip)` returns the fractional part (same type as
/// `x`) and writes the integer part through the out-param. `frexp(x, out
/// e)` returns the mantissa (same type as `x`) and writes the exponent as
/// int/intN. Both rely on б§3.7 out-params; modf maps to each backend's
/// native call directly, while HLSL's `frexp` writes a float exponent and
/// the backend casts it back to the int out-param (see HLSLTarget).
#define BUILTIN_MODF "modf"
#define BUILTIN_FREXP "frexp"

/// б§6.2 Бқ” compute-shader barriers. Both are 0-arg, void-returning, and
/// only valid inside a compute shader. `threadgroupBarrier` is an
/// execution + threadgroup-memory barrier (all threads in the group sync);
/// `deviceBarrier` is a device-memory ordering barrier. Per backend:
///   threadgroupBarrier Б†’ GroupMemoryBarrierWithGroupSync() (HLSL) /
///     threadgroup_barrier(mem_flags::mem_threadgroup) (MSL) / barrier() (GLSL)
///   deviceBarrier Б†’ DeviceMemoryBarrier() (HLSL) /
///     threadgroup_barrier(mem_flags::mem_device) (MSL) / memoryBarrier() (GLSL)
/// Note: HLSL/GLSL `deviceBarrier` is memory-only; MSL additionally syncs
/// execution. The portable contract is "memory ordering only" Бқ” pair with
/// `threadgroupBarrier` when threads must wait.
#define BUILTIN_THREADGROUP_BARRIER "threadgroupBarrier"
#define BUILTIN_DEVICE_BARRIER "deviceBarrier"

/// б§2a follow-up Бқ” mesh-shader runtime output-count call. `setMeshOutputs(nv,
/// np)` sets the *active* per-meshlet vertex and primitive counts before any
/// write to the `out vertices`/`out indices` arrays. Mesh-stage-only,
/// void-returning, `(uint, uint)`. At most one call per shader; when present
/// it replaces the auto-emitted locked-to-maxima
/// `SetMeshOutputsEXT(max_vertices, max_primitives)` Phase 2a inserts at
/// `void main()` entry. Cross-backend lowering is NOT 1:1 (see
/// Mesh-Shader-Implementation-Plan.md Б†’ Cross-Backend Differences Б†’ Active-
/// count "set outputs" call):
///   GLSL Бқ” SetMeshOutputsEXT(nv, np)        (both counts)
///   HLSL Бқ” SetMeshOutputCounts(nv, np)      (both counts)
///   MSL  Бқ” meshOut.set_primitive_count(np)  (vertex count is implicit;
///                                            the `nv` argument is dropped)
#define BUILTIN_SET_MESH_OUTPUTS "setMeshOutputs"

//Internal Shader Attributes
#define ATTRIBUTE_VERTEX_ID "VertexID"
#define ATTRIBUTE_INSTANCE_ID "InstanceID"
#define ATTRIBUTE_POSITION "Position"
#define ATTRIBUTE_COLOR "Color"
#define ATTRIBUTE_TEXCOORD "TexCoord"
#define ATTRIBUTE_GLOBALTHREAD_ID "GlobalThreadID"
#define ATTRIBUTE_THREADGROUP_ID "ThreadGroupID"
#define ATTRIBUTE_LOCALTHREAD_ID "LocalThreadID"
#define ATTRIBUTE_DEPTH "Depth"
#define ATTRIBUTE_FRONTFACING "FrontFacing"
#define ATTRIBUTE_SAMPLEINDEX "SampleIndex"
#define ATTRIBUTE_INPUT_COVERAGE "InputCoverage"
#define ATTRIBUTE_OUTPUT_COVERAGE "OutputCoverage"
/// б§1.7 Бқ” user clip / cull distances on a vertex/hull/domain output struct.
/// Float scalar or float array field. ClipDistance Б†’ SV_ClipDistance /
/// gl_ClipDistance[] / [[clip_distance]] (all backends). CullDistance Б†’
/// SV_CullDistance / gl_CullDistance[] (HLSL/GLSL); Metal has no cull-distance
/// equivalent, so CullDistance is gated by OMEGASL_FEATURE_BIT_CULL_DISTANCE
/// and stubs on MSL.
#define ATTRIBUTE_CLIP_DISTANCE "ClipDistance"
#define ATTRIBUTE_CULL_DISTANCE "CullDistance"
/// б§16 Бқ” tessellation patch-constant / domain semantics. TessFactor and
/// InsideTessFactor are float scalar/array fields on the internal struct a
/// hull's patch-constant function (`patchfn=`) returns; they carry the
/// per-edge and per-inside tessellation amounts (tri: 3 edge + 1 inside;
/// quad: 4 edge + 2 inside). DomainLocation is a `domain`-shader parameter
/// semantic (float3 for tri, float2 for quad) giving the barycentric /
/// (u,v) location the fixed-function tessellator produced. Lowering:
/// SV_TessFactor / SV_InsideTessFactor / SV_DomainLocation (HLSL),
/// gl_TessLevelOuter[]/Inner[] + gl_TessCoord (GLSL), the
/// MTLTriangle/QuadTessellationFactorsHalf buffer + [[position_in_patch]]
/// (MSL).
#define ATTRIBUTE_TESS_FACTOR "TessFactor"
#define ATTRIBUTE_INSIDE_TESS_FACTOR "InsideTessFactor"
#define ATTRIBUTE_DOMAIN_LOCATION "DomainLocation"

