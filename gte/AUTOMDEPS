{
    "project": "OMEGAGTE",
    "variables": {
        "external_lib_path": "./deps"
    },
    "dependencies": [
        {
            "name": "vulkan-memory-allocator",
            "type": "git",
            "url": "https://github.com/GPUOpen-LibrariesAndSDKs/VulkanMemoryAllocator.git",
            "dest": "$(external_lib_path)/vulkan-memory-allocator",
            "platforms": [
                "linux",
                "android"
            ]
        },
        {
            "name": "DirectXMath",
            "type": "git",
            "url": "https://github.com/microsoft/DirectXMath.git",
            "dest": "$(external_lib_path)/DirectXMath",
            "platforms": [
                "windows"
            ]
        },
        {
            "name": "DirectXTex",
            "type": "git",
            "url": "https://github.com/microsoft/DirectXTex.git",
            "dest": "$(external_lib_path)/DirectXTex",
            "platforms": [
                "windows"
            ]
        },
        {
            "name": "DirectXMesh",
            "type": "git",
            "url": "https://github.com/microsoft/DirectXMesh.git",
            "dest": "$(external_lib_path)/DirectXMesh",
            "platforms": [
                "windows"
            ]
        },
        {
            "name": "D3D12MemoryAllocator",
            "type": "git",
            "url": "https://github.com/GPUOpen-LibrariesAndSDKs/D3D12MemoryAllocator.git",
            "dest": "$(external_lib_path)/D3D12MemoryAllocator",
            "platforms": [
                "windows"
            ]
        },
        {
            "name": "cgltf",
            "type": "git",
            "url": "https://github.com/jkuhlmann/cgltf.git",
            "dest": "$(external_lib_path)/cgltf",
            "platforms": [
                "windows",
                "linux",
                "android"
            ]
        },
        {
            "name": "glm",
            "type": "git",
            "url": "https://github.com/g-truc/glm.git",
            "dest": "$(external_lib_path)/glm",
            "platforms": [
                "linux",
                "android"
            ]
        },
        {
            "name": "vulkan-sdk",
            "type": "archive",
            "url": "https://sdk.lunarg.com/sdk/download/latest/linux/vulkan-sdk.tar.gz",
            "dest": "$(external_lib_path)/vulkan_sdk",
            "platforms": [
                "linux"
            ]
        }
    ]
}
